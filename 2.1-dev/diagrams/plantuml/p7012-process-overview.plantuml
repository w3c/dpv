@startuml
!theme plain
actor Person as P
actor PersonAgent as PA
actor EntityAgent as PRA
actor Entity as SP

P --> PA : Sets preferences
PA --> PRA : do you support P7012 protocol?
PRA --> PA : P7012 supported, what are your terms?

alt P7012 Supported
    PA --> PRA : PrivacyTerm X as defined in Registry Y
    
    PRA --> PRA : assess term
    
    alt Term Acceptable
        PRA --> PA : PrivacyTerm accepted, let's execute this contract
        PA --> PRA : agreed (here is the signed contract)
        note over PRA, PA : Contract is signed
        PA --> PA : create a record of this interaction
    else Term Unacceptable - Offer Negotiation
        PRA --> PA : PrivacyTerm X is not acceptable, how about PrivacyTerm Y?
        PA --> PA : assess term
        alt Alternative Term Acceptable
            PA --> PRA : PrivacyTerm Y is acceptable
            PA --> PRA : agreed (here is the signed contract)
            note over PRA, PA : Negotiated contract is signed
        PA --> PA : create a record of this interaction
        else Term Unacceptable
            PA --> PRA: PrivacyTerm Y is not acceptable, negotiation is over
            note over PRA, PA : Contract process terminates
            PA --> PA : create a record of this interaction
        end
    end
else P7012 Not Supported
    note over PRA, PA : No interaction takes place
end
@enduml