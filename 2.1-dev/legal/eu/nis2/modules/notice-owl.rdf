  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/legal/eu/nis2/owl#serialisation-jsonld">
    <dct:title>EU NIS2 - JSON-LD serialiation</dct:title>
    <rdf:type rdf:resource="http://www.w3.org/ns/dx/prof/ResourceDescriptor"/>
    <dct:conformsTo rdf:resource="https://www.w3.org/TR/json-ld11/"/>
    <dct:format rdf:resource="https://www.iana.org/assignments/media-types/application/ld+json"/>
    <profile:hasRole rdf:resource="http://www.w3.org/ns/dx/prof/role/vocabulary"/>
    <profile:hasArtifact rdf:resource="https://w3id.org/dpv/legal/eu/nis2/eu-nis2-owl.jsonld"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/legal/eu/nis2/owl#FinalReport">
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/legal/eu/nis2/owl#"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/risk/owl#IncidentNotice"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">within 1 month of incident handling i.e.  completing the incident recovery and containing the  applied/ongoing measures, 'detailed description' - not sure what this  means, and threat type / root cause - which is covered with threat and  vulnerability concepts</skos:definition>
    <dct:source xml:lang="en">NIS2 Directive</dct:source>
    <skos:prefLabel xml:lang="en">Final Report</skos:prefLabel>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-05-19</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:contributor>Harshvardhan J. Pandit, Georg P. Krog</dct:contributor>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#IncidentNotice"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/primer">
    <dct:format rdf:resource="https://www.iana.org/assignments/media-types/text/html"/>
    <dct:conformsTo rdf:resource="https://www.w3.org/TR/html/"/>
    <dct:title>Primer for Data Privacy Vocabulary</dct:title>
    <profile:hasArtifact rdf:resource="https://w3id.org/dpv/primer"/>
    <profile:hasRole rdf:resource="http://www.w3.org/ns/dx/prof/role/guidance"/>
    <rdf:type rdf:resource="http://www.w3.org/ns/dx/prof/ResourceDescriptor"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/legal/eu/nis2/owl#serialisation-ttl">
    <profile:hasRole rdf:resource="http://www.w3.org/ns/dx/prof/role/vocabulary"/>
    <dct:conformsTo rdf:resource="https://www.w3.org/TR/turtle/"/>
    <dct:title>EU NIS2 - Turtle serialiation</dct:title>
    <dct:format rdf:resource="https://www.iana.org/assignments/media-types/text/turtle"/>
    <profile:hasArtifact rdf:resource="https://w3id.org/dpv/legal/eu/nis2/eu-nis2-owl.ttl"/>
    <rdf:type rdf:resource="http://www.w3.org/ns/dx/prof/ResourceDescriptor"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/legal/eu/nis2/owl#InitialFeedbackOnIncident">
    <rdf:type rdf:resource="https://w3id.org/dpv/risk/owl#IncidentNotice"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">Notification from authority to organisation (upon request, within 24 hours or early warning) containing  "initial feedback" and guidelines on measures that can be taken in  response to a breach</skos:definition>
    <skos:prefLabel xml:lang="en">Initial Feedback on Incident</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/legal/eu/nis2/owl#"/>
    <dct:source xml:lang="en">NIS2 Directive</dct:source>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-05-19</dct:created>
    <dct:contributor>Harshvardhan J. Pandit, Georg P. Krog</dct:contributor>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#IncidentNotice"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/legal/eu/nis2/owl#IntermediateReport">
    <skos:prefLabel xml:lang="en">Intermediate Report</skos:prefLabel>
    <rdf:type rdf:resource="https://w3id.org/dpv/risk/owl#IncidentNotice"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:source xml:lang="en">NIS2 Directive</dct:source>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-05-19</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:contributor>Harshvardhan J. Pandit, Georg P. Krog</dct:contributor>
    <skos:definition xml:lang="en">upon request - which provides updates, if any,  to previous information</skos:definition>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/legal/eu/nis2/owl#"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#IncidentNotice"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/legal/eu/nis2/owl#ProgressReport">
    <dct:source xml:lang="en">NIS2 Directive</dct:source>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-05-19</dct:created>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/risk/owl#IncidentNotice"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:contributor>Harshvardhan J. Pandit, Georg P. Krog</dct:contributor>
    <skos:definition xml:lang="en">within 1 month of detection if the  incident handling has not been completed by then, with updates to  previous information</skos:definition>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/legal/eu/nis2/owl#"/>
    <skos:prefLabel xml:lang="en">Progress Report</skos:prefLabel>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#IncidentNotice"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/legal/eu/nis2/owl#SignificantIncidentNotice">
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:contributor>Harshvardhan J. Pandit, Georg P. Krog</dct:contributor>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/legal/eu/nis2/owl#"/>
    <skos:prefLabel xml:lang="en">Significant Incident Notice</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:source xml:lang="en">NIS2 Directive</dct:source>
    <skos:definition xml:lang="en">Notice sent for reporting significant incidents</skos:definition>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-05-19</dct:created>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#IncidentNotice"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/legal/eu/nis2/owl#IncidentAssessmentReport">
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/legal/eu/nis2/owl#"/>
    <dct:source xml:lang="en">NIS2 Directive</dct:source>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/risk/owl#IncidentNotice"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:prefLabel xml:lang="en">Incident Assessment Report</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-05-19</dct:created>
    <dct:contributor>Harshvardhan J. Pandit, Georg P. Krog</dct:contributor>
    <skos:definition xml:lang="en">within 72 hours of detection, which contains  updates on the earlier information as well as initial assessment of  severity and impact of the incident as well as any 'indicators of  compromise'</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#IncidentNotice"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/legal/eu/nis2/owl#serialisation-rdf">
    <dct:format rdf:resource="https://www.iana.org/assignments/media-types/application/rdf+xml"/>
    <dct:title>EU NIS2 - RDF/XML serialiation</dct:title>
    <rdf:type rdf:resource="http://www.w3.org/ns/dx/prof/ResourceDescriptor"/>
    <profile:hasRole rdf:resource="http://www.w3.org/ns/dx/prof/role/vocabulary"/>
    <profile:hasArtifact rdf:resource="https://w3id.org/dpv/legal/eu/nis2/eu-nis2-owl.rdf"/>
    <dct:conformsTo rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/guides">
    <profile:hasRole rdf:resource="http://www.w3.org/ns/dx/prof/role/guidance"/>
    <dct:title>Guides for Data Privacy Vocabulary</dct:title>
    <dct:format rdf:resource="https://www.iana.org/assignments/media-types/text/html"/>
