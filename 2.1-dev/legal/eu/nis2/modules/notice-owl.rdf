  <rdf:Description rdf:about="https://w3id.org/dpv/legal/eu/nis2/owl#EarlyWarningReport">
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-05-19</dct:created>
    <skos:prefLabel xml:lang="en">Early Warning Report</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/risk/owl#IncidentNotice"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:contributor>Harshvardhan J. Pandit, Georg P. Krog</dct:contributor>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/legal/eu/nis2/owl#"/>
    <skos:definition xml:lang="en">within 24 hours of detection containing cause of the  incident and whether it was unlawful or malicious and whether there is  cross-border impact</skos:definition>
    <dct:source xml:lang="en">NIS2 Directive</dct:source>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#IncidentNotice"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/legal/eu/nis2/owl#RiskMitigationAdvice">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/risk/owl#IncidentNotice"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/legal/eu/nis2/owl#"/>
    <dct:source xml:lang="en">NIS2 Directive</dct:source>
    <skos:prefLabel xml:lang="en">Risk Mitigation Advice</skos:prefLabel>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-05-19</dct:created>
    <skos:definition xml:lang="en">Notification from organisation to stakeholders regarding risk mitigations to be applied and existence of threats</skos:definition>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:contributor>Harshvardhan J. Pandit, Georg P. Krog</dct:contributor>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#IncidentNotice"/>
  </rdf:Description>
