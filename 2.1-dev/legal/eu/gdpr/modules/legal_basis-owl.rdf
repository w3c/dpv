  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/legal/eu/gdpr/owl#A6-1-a-explicit-consent">
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#"/>
    <skos:scopeNote xml:lang="en">Valid consent in this case would have requirements for being 'explicit' in addition to requirements defined by A4-11. This is also mentioned in the Article 29 Working Party document "Guidelines on Consent under Regulation 2016/679 (wp259rev.01)"</skos:scopeNote>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-06-22</dct:created>
    <skos:definition xml:lang="en">Legal basis based on data subject's given explicit consent to the processing of his or her personal data for one or more specific purposes</skos:definition>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:prefLabel xml:lang="en">Art 6(1-a) explicit consent</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#LegalBasis"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-11-24</dct:modified>
    <dct:contributor>Eva Schlehahn, Bud Bruegger, Harshvardhan J. Pandit, Rigo Wenning</dct:contributor>
    <dct:source rdf:nodeID="Nb4d2083739c042f7b182323080020b45"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#ExplicitlyExpressedConsent"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#A6-1-a"/>
  </rdf:Description>
