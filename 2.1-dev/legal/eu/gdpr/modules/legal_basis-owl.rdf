    <dct:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-02-15</dct:modified>
    <skos:definition xml:lang="en">Legal basis based on protecting the vital interests of another natural person that is not the data subject</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#A6-1-d"/>
