    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Contract"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#DataTransferLegalBasis"/>
  </rdf:Description>
