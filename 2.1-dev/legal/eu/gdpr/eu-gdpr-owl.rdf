  <rdf:Description rdf:about="https://w3id.org/dpv/legal/eu/gdpr/owl#TransparencyPrinciple">
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#OrganisationalMeasure"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:contributor>Georg P. Krog</dct:contributor>
    <skos:prefLabel xml:lang="en">Transparency Principle</skos:prefLabel>
    <skos:definition xml:lang="en">Principle stating personal data must be processed processed in a transparent manner in relation to the data subject</skos:definition>
    <dct:source xml:lang="en">GDPR Art.5-1a</dct:source>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-05-12</dct:created>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Principle"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/legal/eu/gdpr/owl#DirectDataCollectionNotice">
