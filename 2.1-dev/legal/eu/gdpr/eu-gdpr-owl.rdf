  <rdf:Description rdf:about="https://w3id.org/dpv/legal/eu/gdpr/owl#A6-1-f-third-party">
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#LegalBasis"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dpv-owl:hasRight rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#A16"/>
    <dpv-owl:hasRight rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#A15"/>
    <dpv-owl:hasRight rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#A13"/>
    <dpv-owl:hasRight rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#A77"/>
    <dpv-owl:hasRight rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#A21"/>
    <dpv-owl:hasRight rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#A22"/>
    <dpv-owl:hasRight rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#A14"/>
    <dpv-owl:hasRight rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#A18"/>
    <dpv-owl:hasRight rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#A17"/>
    <dct:source rdf:nodeID="Na904c8dfaaf24c61b06b7ca8f2178100"/>
    <dct:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-11-24</dct:modified>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#"/>
    <skos:prefLabel xml:lang="en">Art 6(1-f) legitimate interest of third party</skos:prefLabel>
    <dct:contributor>Georg P. Krog</dct:contributor>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-11-24</dct:created>
    <skos:definition xml:lang="en">Legal basis based on the purposes of the legitimate interests pursued by a third party, except where such interests are overridden by the interests or fundamental rights and freedoms of the data subject which require protection of personal data, in particular where the data subject is a child</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#A6-1-f"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#LegitimateInterestOfThirdParty"/>
  </rdf:Description>
