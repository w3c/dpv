  <rdf:Description rdf:nodeID="N3d8ad699c15e4594afe09ddd614e0681">
    <rdf:type rdf:resource="https://schema.org/WebPage"/>
    <schema:url>https://eur-lex.europa.eu/eli/reg/2016/679/art_9/par_2/pnt_j/oj</schema:url>
