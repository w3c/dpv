    <skos:definition xml:lang="en">Notice sent to a DPA in phases i.e. by providing incremental information as it becomes available or is requested following previously submitted notifications</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
