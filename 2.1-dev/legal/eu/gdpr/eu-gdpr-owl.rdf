    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A Notice provided in fulfilment of GDPR's Art.13 regarding information to be provided where personal data are collected from the data subject</skos:definition>
    <skos:prefLabel xml:lang="en">Direct Data Collection Notice</skos:prefLabel>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-11-09</dct:created>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RightFulfilmentNotice"/>
  </rdf:Description>
