    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#DPIAOutcomeStatus"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/dc/terms/title">
