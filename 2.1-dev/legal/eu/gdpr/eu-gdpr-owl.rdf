    <skos:prefLabel xml:lang="en">Art 6(1-d) protect vital interests of natural person</skos:prefLabel>
    <dct:source rdf:nodeID="Nc1a1ddc2840747f2843e05903fa5e7ab"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-02-15</dct:modified>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#VitalInterestOfNaturalPerson"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#A6-1-d"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/legal/eu/gdpr/owl#hasLeadSA">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-02-14</dct:created>
