    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">A Notice provided in fulfilment of GDPR's Art.14 regarding information to be provided where personal data are not collected from the data subject</skos:definition>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#"/>
    <skos:prefLabel xml:lang="en">Indirect Data Collection Notice</skos:prefLabel>
