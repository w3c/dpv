  <rdf:Description rdf:nodeID="Nba9bbe9f4bd446cf90cd1a91a0e05ebb">
    <schema:name>EDPB Recommendations 01/2020 on Supplementary Measures and Transfer Tools</schema:name>
    <schema:url>https://edpb.europa.eu/sites/default/files/consultation/edpb_recommendations_202001_supplementarymeasurestransferstools_en.pdf</schema:url>
    <rdf:type rdf:resource="https://schema.org/WebPage"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/legal/eu/gdpr/owl#A49-1-a">
    <skos:scopeNote xml:lang="en">Transfer from EU to a third country. Third country has no Adequacy Decision. Appropriate safeguards do not exist.</skos:scopeNote>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:source rdf:nodeID="N68f6bdc3530a4576b8b34f52730ce39f"/>
    <dct:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-06-22</dct:modified>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#"/>
    <skos:definition xml:lang="en">The data subject has explicitly consented to the proposed transfer, after having been informed of the possible risks of such transfers for the data subject due to the absence of an adequacy decision and appropriate safeguards.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#LegalBasis"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2020-11-04</dct:created>
    <skos:prefLabel xml:lang="en">Art 49(1-a) explicit consent</skos:prefLabel>
    <dct:contributor>Georg P. Krog</dct:contributor>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#ExplicitlyExpressedConsent"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#DataTransferLegalBasis"/>
  </rdf:Description>
