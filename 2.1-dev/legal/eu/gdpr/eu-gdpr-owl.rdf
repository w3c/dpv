    <dct:source xml:lang="en">GDPR Art.56</dct:source>
    <skos:definition xml:lang="en">Indicates the lead supervisory authority</skos:definition>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dcam:rangeIncludes rdf:resource="https://w3id.org/dpv/owl#DataProtectionAuthority"/>
