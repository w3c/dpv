    <schema:name>GDPR Art.46-2b</schema:name>
    <schema:url>https://eur-lex.europa.eu/eli/reg/2016/679/art_46/par_2/pnt_b/oj</schema:url>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/legal/eu/gdpr/owl#DataProtectionAuthority">
    <dct:contributor>Harshvardhan J. Pandit, Georg P. Krog</dct:contributor>
    <dct:source xml:lang="en"> Guidelines 3/2018 on the territorial scope of the GDPR (Article 3) Version 2.1</dct:source>
    <dct:source xml:lang="en">GDPR Art.56</dct:source>
    <skos:definition xml:lang="en">A Supervisory Authority responsible for the enfocement of the GDPR</skos:definition>
    <skos:prefLabel xml:lang="en">Data Protection Authority</skos:prefLabel>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-06-22</dct:created>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#DataProtectionAuthority"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/legal/eu/gdpr/owl#A9-2-c">
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:prefLabel xml:lang="en">Art 9(2-c) protect vital interest</skos:prefLabel>
    <dct:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-09-08</dct:modified>
