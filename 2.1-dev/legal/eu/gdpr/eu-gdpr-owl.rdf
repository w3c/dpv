    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#"/>
    <skos:definition xml:lang="en">A Notice provided in fulfilment of GDPR's Art.19 regarding Recipients to whom a rights exercise has been communicated, such as regarding rectification (A.16) or erasure of personal data (A.17) or restriction of processing (A.18)</skos:definition>
    <dct:contributor>Beatriz Esteves, Georg P. Krog, Harshvardhan J. Pandit</dct:contributor>
    <skos:prefLabel xml:lang="en">Rights Recipients Notice</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RightFulfilmentNotice"/>
  </rdf:Description>
