    <skos:definition xml:lang="en">Authority with the primary responsibility for dealing with a cross-border data processing activity</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/dc/terms/coverage">
    <skos:scopeNote xml:lang="en">For expressing coverage (e.g. jurisdictions, products, services) of the DPIA document or process. For temporal coverage, please see dct:temporal. The coverage can be expressed using dpv:Process, or using another concept, or even be a link or reference to a document, or a textual description</skos:scopeNote>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/legal/eu/gdpr/owl#"/>
    <skos:prefLabel xml:lang="en">dct:coverage</skos:prefLabel>
