    <profile:hasArtifact rdf:resource="https://w3id.org/dpv/legal/eu/aiact/eu-aiact-owl.jsonld"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/legal/eu/aiact/owl#serialisation-html">
    <dct:title>EU AI Act - HTML serialiation</dct:title>
    <profile:hasRole rdf:resource="http://www.w3.org/ns/dx/prof/role/specification"/>
    <dct:format rdf:resource="https://www.iana.org/assignments/media-types/text/html"/>
