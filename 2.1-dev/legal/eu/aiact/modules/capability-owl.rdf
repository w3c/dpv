  <rdf:Description rdf:about="https://w3id.org/dpv/legal/eu/aiact/owl#EmotionRecognition">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:prefLabel xml:lang="en">Emotion Recognition</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:related rdf:resource="https://w3id.org/dpv/pd/owl#Biometric"/>
    <dct:contributor>Delaram Golpayegani</dct:contributor>
    <skos:definition xml:lang="en">Capability of a technology to identify or infer emotions or intentions of natural persons [on the basis of their biometric data]</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/tech/owl#Capability"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/legal/eu/aiact/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-10</dct:created>
  </rdf:Description>
