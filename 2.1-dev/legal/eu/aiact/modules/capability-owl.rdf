  <rdf:Description rdf:about="https://w3id.org/dpv/legal/eu/aiact/owl#BiometricIdentityVerification">
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/legal/eu/aiact/owl#"/>
    <skos:related rdf:resource="https://w3id.org/dpv/pd/owl#Biometric"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Purpose"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-10</dct:created>
    <dct:contributor>Delaram Golpayegani</dct:contributor>
    <dct:source xml:lang="en">AIA(Art. 3(33c))</dct:source>
    <skos:definition xml:lang="en">The automated verification of the identity of natural persons by comparing biometric data of an individual to previously provided biometric data (one-to-one verification, including authentication).</skos:definition>
    <skos:scopeNote xml:lang="en">Parent could be dpv:IdentityVerification</skos:scopeNote>
    <skos:prefLabel xml:lang="en">Biometric Identity Verification</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/examples">
    <dct:title>Examples for Data Privacy Vocabulary</dct:title>
    <profile:hasRole rdf:resource="http://www.w3.org/ns/dx/prof/role/guidance"/>
    <dct:format rdf:resource="https://www.iana.org/assignments/media-types/text/html"/>
