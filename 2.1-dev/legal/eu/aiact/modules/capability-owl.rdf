  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/legal/eu/aiact/owl#serialisation-ttl">
    <dct:format rdf:resource="https://www.iana.org/assignments/media-types/text/turtle"/>
    <dct:conformsTo rdf:resource="https://www.w3.org/TR/turtle/"/>
    <rdf:type rdf:resource="http://www.w3.org/ns/dx/prof/ResourceDescriptor"/>
    <profile:hasRole rdf:resource="http://www.w3.org/ns/dx/prof/role/vocabulary"/>
    <profile:hasArtifact rdf:resource="https://w3id.org/dpv/legal/eu/aiact/eu-aiact-owl.ttl"/>
    <dct:title>EU AI Act - Turtle serialiation</dct:title>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/legal/eu/aiact/owl#BiometricIdentification">
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:related rdf:resource="https://w3id.org/dpv/pd/owl#Biometric"/>
    <dct:source xml:lang="en">AIA(Art. 3(33a))</dct:source>
    <skos:definition xml:lang="en">The automated recognition of physical, physiological, behavioural, and psychological human features for the purpose of establishing an individual’s identity by comparing biometric data of that individual to stored biometric data of individuals in a database</skos:definition>
    <skos:prefLabel xml:lang="en">Biometric Identification</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/legal/eu/aiact/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-10</dct:created>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/tech/owl#Capability"/>
    <dct:contributor>Delaram Golpayegani</dct:contributor>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/legal/eu/aiact/owl#HighImpactCapabilityGPAIModel">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/tech/owl#Capability"/>
    <skos:prefLabel xml:lang="en">High-Impact Capability in General Purpose AI Models</skos:prefLabel>
    <skos:definition xml:lang="en">‘high-impact capabilities’ in general purpose AI models means capabilities that match or exceed the capabilities recorded in the most  advanced general purpose AI models.</skos:definition>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/legal/eu/aiact/owl#"/>
    <dct:source xml:lang="en">AIA(Art. 3(44c))</dct:source>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:contributor>Delaram Golpayegani</dct:contributor>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-10</dct:created>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/legal/eu/aiact/owl#serialisation-jsonld">
    <rdf:type rdf:resource="http://www.w3.org/ns/dx/prof/ResourceDescriptor"/>
    <profile:hasRole rdf:resource="http://www.w3.org/ns/dx/prof/role/vocabulary"/>
