  <rdf:Description rdf:about="https://w3id.org/dpv/sector/education/owl#EducationStudentOnlineProctoring">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#Purpose"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:prefLabel xml:lang="en">Education - Student Online Proctoring</skos:prefLabel>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-01</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Purposes associated with online or virtual or remote proctoring i.e. monitoring of students present virtually over an online platform or within their remote physical location during an assessment with the aim of ensuring they do not cheat</skos:definition>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/sector/education/owl#"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/sector/owl#EducationStudentProctoring"/>
  </rdf:Description>
