    <skos:definition xml:lang="en">Purposes associated with provision of educational services, including lectures, seminars, laboratory work, and other similar activities within the context of provision of education</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#ServiceProvision"/>
