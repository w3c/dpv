  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/sector/education/owl#EducationServiceProvision">
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-01</dct:created>
