    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#PurposeTransparencyRequired"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#TrackingDisallowed">
