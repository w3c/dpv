    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">Term that indicates Profiling is allowed but only if it does not involve Fingerprinting</skos:definition>
    <skos:prefLabel xml:lang="en">Profiling Allowed No FP</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ProfilingAllowed"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#TransparencyOnRequest">
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#TransparencyTerm"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
