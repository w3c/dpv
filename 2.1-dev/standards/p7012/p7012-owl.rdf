  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#DataTransparencyTerm">
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <skos:prefLabel xml:lang="en">Data Transparency Term</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <skos:definition xml:lang="en">Term that indicates transparency regarding data involved and its source as an obligation</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#ContractualClause"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#SharingDataDisallowed">
    <skos:prefLabel xml:lang="en">Sharing Data Disallowed</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <rdf:value>dpv:Prohibition</rdf:value>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#DataSharingTerm"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">Term that indicates Data Sharing is not allowed</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#DataSharingTerm"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#PortabilityRequiredOnRequest">
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:prefLabel xml:lang="en">Portability Required On Request</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <skos:definition xml:lang="en">Term that indicates data should be ported or made available on request</skos:definition>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#PortabilityTerm"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdf:value>dpv:Obligation</rdf:value>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#PortabilityRequired"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#AgreementRefused">
    <skos:prefLabel xml:lang="en">Agreement Refused</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#AgreementNegotiationStatus"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <skos:definition xml:lang="en">Status indicating the Agreement Negotiation is completed and the parties have refused the relevant terms</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#AgreementNegotiationStatus"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#AgentDisallowsNegotiation">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#AgentNegotiationBehaviour"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <skos:prefLabel xml:lang="en">Agent Disallows Negotiation</skos:prefLabel>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Term that indicates the Agent should not allow any negotiations</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#AgentNegotiationBehaviour"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#AgentRequestBehaviour">
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Term that indicates the behaviour of the Agent in relation to requests</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#AgentBehaviour"/>
    <skos:prefLabel xml:lang="en">Agent Request Behaviour</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#AgreementNegotiationClarificationRequired">
    <skos:prefLabel xml:lang="en">Agreement Negotiation Clarification Required</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#AgreementNegotiationStatus"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Status indicating the Agreement Negotiation requires a clarification from the other party regarding the relevant context</skos:definition>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#AgreementNegotiationStatus"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#PartyTransparencyExPost">
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdf:value>dpv:Obligation</rdf:value>
    <skos:prefLabel xml:lang="en">Party Transparency Ex Post</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#PartyTransparencyTerm"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">Term that indicates transparency regarding identities and involvement of parties in specific roles is obligated after intended process i.e. ex-post transparency regarding identities and involvement of parties in specific roles</skos:definition>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#PartyTransparencyRequired"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#SD-BY-A">
    <skos:prefLabel xml:lang="en">SD BY-A</skos:prefLabel>
    <skos:definition xml:lang="en">Term that requires Service Delivery and permits Analytics, and prohibits Analytics by 3rd Party, prohibits Tracking, or Profiling by 2nd and 3rd Party, and prohibits sharing any data with 3rd Party</skos:definition>
    <dpv-owl:hasObligation rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ServiceDeliveryRequired"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Agreement"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <dpv-owl:hasProhibition rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Analytics3PDisallowed"/>
    <dpv-owl:hasProhibition rdf:resource="https://w3id.org/dpv/standards/p7012/owl#DataSharingDisallowed"/>
    <dpv-owl:hasProhibition rdf:resource="https://w3id.org/dpv/standards/p7012/owl#TrackingDisallowed"/>
    <dpv-owl:hasProhibition rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ProfilingDisallowed"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dpv-owl:hasPermission rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Analytics2PAllowed"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#SD-BY"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#serialisation-rdf">
    <profile:hasRole rdf:resource="http://www.w3.org/ns/dx/prof/role/vocabulary"/>
    <dct:format rdf:resource="https://www.iana.org/assignments/media-types/application/rdf+xml"/>
    <dct:conformsTo rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#"/>
    <rdf:type rdf:resource="http://www.w3.org/ns/dx/prof/ResourceDescriptor"/>
    <profile:hasArtifact rdf:resource="https://w3id.org/dpv/standards/p7012/p7012-owl.rdf"/>
    <dct:title>Extension for IEEE P7012 - RDF/XML serialiation</dct:title>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#ResolveByDiscarding">
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ConflictResolutionTerm"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Term that indicates a conflict should be resolved by discarding the conflicting terms i.e. removing all terms that are in conflict</skos:definition>
    <skos:prefLabel xml:lang="en">Resolve By Discarding</skos:prefLabel>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ConflictResolutionTerm"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#ThirdParty">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#LegalEntity"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:prefLabel xml:lang="en">Third Party</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">A party other than the Person and Entity as first and second parties respectively in the contractual interaction</skos:definition>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#serialisation-ttl">
    <rdf:type rdf:resource="http://www.w3.org/ns/dx/prof/ResourceDescriptor"/>
    <profile:hasRole rdf:resource="http://www.w3.org/ns/dx/prof/role/vocabulary"/>
    <profile:hasArtifact rdf:resource="https://w3id.org/dpv/standards/p7012/p7012-owl.ttl"/>
    <dct:title>Extension for IEEE P7012 - Turtle serialiation</dct:title>
    <dct:format rdf:resource="https://www.iana.org/assignments/media-types/text/turtle"/>
    <dct:conformsTo rdf:resource="https://www.w3.org/TR/turtle/"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/examples">
    <dct:title>Examples for Data Privacy Vocabulary</dct:title>
    <dct:conformsTo rdf:resource="https://www.w3.org/TR/html/"/>
    <dct:format rdf:resource="https://www.iana.org/assignments/media-types/text/html"/>
    <profile:hasArtifact rdf:resource="https://w3id.org/dpv/examples"/>
    <rdf:type rdf:resource="http://www.w3.org/ns/dx/prof/ResourceDescriptor"/>
    <profile:hasRole rdf:resource="http://www.w3.org/ns/dx/prof/role/guidance"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#AgreementRegistry">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">A registry hosting agreements that acts as a common repository for parties to utilise as a reference within requests and for negotiating acceptable terms</skos:definition>
    <skos:prefLabel xml:lang="en">Agreement Term Registry</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#PDC-INTENT">
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Agreement"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:prefLabel xml:lang="en">Personal Data Contribution for Intent Casting</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <skos:definition xml:lang="en">Term that indicates access to data is being provided for the purposes of Intent Casting</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#PDC"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#AgreementPreference">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Rule"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <skos:prefLabel xml:lang="en">Agreement Preference</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A preference regarding agreements, such as to indicate which terms are acceptable or unacceptable</skos:definition>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#hasMachineReadableFormat">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <schema:rangeIncludes rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <dcam:rangeIncludes rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:scopeNote xml:lang="en">To assist in interpreting the resource, we strongly suggest using dct:conformsTo with an appropriate URI to indicate the specific standard or specification used to express the resource</skos:scopeNote>
    <skos:definition xml:lang="en">Indicates the specified resource is a machine readable format of the subject</skos:definition>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <skos:prefLabel xml:lang="en">has machine readable format</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#PurposeTransparencyExAnte">
    <rdf:value>dpv:Obligation</rdf:value>
    <skos:definition xml:lang="en">Term that indicates transparency regarding purposes involved for processing of data and technologies is obligated ahead of intended process i.e. ex-ante transparency regarding purposes involved for processing of data and technologies</skos:definition>
    <skos:prefLabel xml:lang="en">Purpose Transparency Ex Ante</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#PurposeTransparencyTerm"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#PurposeTransparencyRequired"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#hasPreferenceApplicability">
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Relation that indicates the applicability of Privacy Preference(s)</skos:definition>
    <skos:prefLabel xml:lang="en">has preference applicability</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcam:rangeIncludes rdf:resource="https://w3id.org/dpv/standards/p7012/owl#PreferenceApplicability"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <schema:rangeIncludes rdf:resource="https://w3id.org/dpv/standards/p7012/owl#PreferenceApplicability"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#Agent">
    <skos:definition xml:lang="en">An Agent is any software or a combination of software and hardware that works exclusively for its party, and which may be provided by a third party but must be controlled and be responsible to the party it represents</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:prefLabel xml:lang="en">Agent</skos:prefLabel>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Entity"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#hasConflictResolution">
    <skos:definition xml:lang="en">Relation that indicates the Conflict Resolution Term that should be used</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcam:rangeIncludes rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ConflictResolutionTerm"/>
    <schema:rangeIncludes rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ConflictResolutionTerm"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <skos:prefLabel xml:lang="en">has conflict resolution</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#hasThirdParty">
    <dcam:rangeIncludes rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ThirdParty"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <schema:rangeIncludes rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ThirdParty"/>
    <rdfs:subPropertyOf rdf:resource="https://w3id.org/dpv/owl#hasThirdParty"/>
    <skos:definition xml:lang="en">Specifies the a party other than the person or Entity that is involved</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <skos:prefLabel xml:lang="en">has third party</skos:prefLabel>
  </rdf:Description>
</rdf:RDF>
