    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">Term that indicates the behaviour of the Agent</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#PartyTransparencyOnRequest">
    <skos:definition xml:lang="en">Term that indicates transparency regarding identities and involvement of parties in specific roles is obligated upon request</skos:definition>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
