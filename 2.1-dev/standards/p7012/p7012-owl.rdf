  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#PurposeTransparencyNotRequired">
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:prefLabel xml:lang="en">Purpose Transparency Not Required</skos:prefLabel>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#PurposeTransparencyTerm"/>
