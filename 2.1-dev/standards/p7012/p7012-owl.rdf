>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#AgreementNegotiationRequested">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#AgreementNegotiationStatus"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:prefLabel xml:lang="en">Agreement Negotiation Requested</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <skos:definition xml:lang="en">Status indicating the Agreement Negotiation has been requested to be initiated</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#AgreementNegotiationStatus"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#ServiceImprovement">
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:prefLabel xml:lang="en">Service Improvement</skos:prefLabel>
    <skos:definition xml:lang="en">Purposes associated with identifying and implementing improvements to a service</skos:definition>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#Purpose"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Purpose"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#PortabilityToThirdParty">
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdf:value>dpv:Obligation</rdf:value>
    <skos:definition xml:lang="en">Term that indicates data should be ported or made available to third party</skos:definition>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#PortabilityTerm"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:prefLabel xml:lang="en">Portability To Third Party</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#PortabilityRequired"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#Profiling2PAllowed">
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ProfilingTerm"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdf:value>dpv:Permission</rdf:value>
    <skos:prefLabel xml:lang="en">Profiling Allowed Only First Party</skos:prefLabel>
    <skos:definition xml:lang="en">Term that indicates Profiling is allowed but only by the 1st Party</skos:definition>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ProfilingAllowed"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#AgreementNegotiationRefused">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#AgreementNegotiationStatus"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <skos:prefLabel xml:lang="en">Agreement Negotiation Refused</skos:prefLabel>
    <skos:definition xml:lang="en">Status indicating the Agreement Negotiation has been refused to be initiated or continued</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#AgreementNegotiationStatus"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#SD-BY-A-DP">
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Agreement"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Term that requires Service Delivery and permits Analytics, with an obligation for Data Portability, and prohibits Analytics by 3rd Party, prohibits Tracking or Profiling by 2nd and 3rd Party, and prohibits sharing any data with 3rd Party</skos:definition>
    <dpv-owl:hasProhibition rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Analytics3PDisallowed"/>
    <dpv-owl:hasProhibition rdf:resource="https://w3id.org/dpv/standards/p7012/owl#TrackingDisallowed"/>
    <dpv-owl:hasProhibition rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ProfilingDisallowed"/>
    <dpv-owl:hasProhibition rdf:resource="https://w3id.org/dpv/standards/p7012/owl#DataSharingDisallowed"/>
    <skos:prefLabel xml:lang="en">SD BY-A-DP</skos:prefLabel>
    <dpv-owl:hasObligation rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ServiceDeliveryRequired"/>
    <dpv-owl:hasObligation rdf:resource="https://w3id.org/dpv/standards/p7012/owl#PortabilityRequired"/>
    <dpv-owl:hasPermission rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Analytics2PAllowed"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#SD-BY-A"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#SD-BY-DP"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#PreferenceConditionallyApplies">
    <skos:prefLabel xml:lang="en">Preference Conditionally Applies</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#PreferenceApplicability"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Term that indicates the privacy preference conditionally applies i.e. it should only be used in agreements and negotiations if the associated condition is satisfied within the context</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#PreferenceApplicability"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#serialisation-n3">
    <rdf:type rdf:resource="http://www.w3.org/ns/dx/prof/ResourceDescriptor"/>
    <profile:hasRole rdf:resource="http://www.w3.org/ns/dx/prof/role/vocabulary"/>
    <dct:format rdf:resource="https://www.iana.org/assignments/media-types/text/n3"/>
    <dct:conformsTo rdf:resource="https://www.w3.org/TeamSubmission/n3/"/>
    <dct:title>Extension for IEEE P7012 - N3 serialiation</dct:title>
    <profile:hasArtifact rdf:resource="https://w3id.org/dpv/standards/p7012/p7012-owl.n3"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#PortabilityNotRequired">
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdf:value>dpv:Obligation</rdf:value>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:prefLabel xml:lang="en">Portability Not Required</skos:prefLabel>
    <skos:definition xml:lang="en">Term that indicates data portability is not required to be provided</skos:definition>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#PortabilityTerm"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#PortabilityRequired"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#hasParty">
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <schema:rangeIncludes rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Party"/>
    <skos:definition xml:lang="en">Specifies that an entity is a party to the context i.e. it has decision making abilities or has obligations and responsibilities</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:subPropertyOf rdf:resource="https://w3id.org/dpv/owl#hasEntity"/>
    <dcam:rangeIncludes rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Party"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <skos:prefLabel xml:lang="en">has party</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#hasTrackingTerm">
    <schema:rangeIncludes rdf:resource="https://w3id.org/dpv/standards/p7012/owl#TrackingTerm"/>
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcam:rangeIncludes rdf:resource="https://w3id.org/dpv/standards/p7012/owl#TrackingTerm"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:prefLabel xml:lang="en">has tracking term</skos:prefLabel>
    <skos:definition xml:lang="en">Relation that associates a Tracking Term</skos:definition>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#ProfilingDisallowed">
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <skos:definition xml:lang="en">Term that indicates Profiling is not allowed</skos:definition>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ProfilingTerm"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdf:value>dpv:Prohibition</rdf:value>
    <skos:prefLabel xml:lang="en">Profiling Disallowed</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ProfilingTerm"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#AgentDisallowsRequests">
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#AgentRequestBehaviour"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:prefLabel xml:lang="en">Agent Disallows Requests</skos:prefLabel>
    <skos:definition xml:lang="en">Term that indicates the Agent should not allow any requests to be made</skos:definition>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#AgentRequestBehaviour"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#SD-BY">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Agreement"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <skos:prefLabel xml:lang="en">SD-BY</skos:prefLabel>
    <dpv-owl:hasProhibition rdf:resource="https://w3id.org/dpv/standards/p7012/owl#DataSharingDisallowed"/>
    <dpv-owl:hasProhibition rdf:resource="https://w3id.org/dpv/standards/p7012/owl#TrackingDisallowed"/>
    <dpv-owl:hasProhibition rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ProfilingDisallowed"/>
    <dpv-owl:hasProhibition rdf:resource="https://w3id.org/dpv/standards/p7012/owl#AnalyticsDisallowed"/>
    <skos:definition xml:lang="en">Term that requires Service Delivery, and prohibits Analytics, Tracking, or Profiling by 2nd and 3rd Party, and prohibits sharing any data with 3rd Party</skos:definition>
    <dpv-owl:hasObligation rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ServiceDeliveryRequired"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Agreement"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#TrackingWithoutFPAllowed">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#TrackingTerm"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">Term that indicates Tracking is allowed but only if it does not involve Fingerprinting</skos:definition>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <skos:prefLabel xml:lang="en">Tracking Without FP Allowed</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdf:value>dpv:Permission</rdf:value>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#TrackingAllowed"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#AgreementNegotiationUnknown">
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#AgreementNegotiationStatus"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <skos:definition xml:lang="en">Status indicating the state of Agreement Negotiation is unknown</skos:definition>
    <skos:prefLabel xml:lang="en">Agreement Negotiation Unknown</skos:prefLabel>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#AgreementNegotiationStatus"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#SD-BY-AT-DP">
    <dpv-owl:hasPermission rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Tracking2PAllowed"/>
    <dpv-owl:hasPermission rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Analytics2PAllowed"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Agreement"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dpv-owl:hasObligation rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ServiceDeliveryRequired"/>
    <dpv-owl:hasObligation rdf:resource="https://w3id.org/dpv/standards/p7012/owl#PortabilityRequired"/>
    <dpv-owl:hasProhibition rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ProfilingDisallowed"/>
    <dpv-owl:hasProhibition rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Analytics3PDisallowed"/>
    <dpv-owl:hasProhibition rdf:resource="https://w3id.org/dpv/standards/p7012/owl#DataSharingDisallowed"/>
    <dpv-owl:hasProhibition rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Tracking3PDisallowed"/>
    <skos:prefLabel xml:lang="en">SD BY-AT-DP</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <skos:definition xml:lang="en">Term that requires Service Delivery, and permits Analytics and Tracking by the 2nd Party, with an obligation for Data Portability, and prohibits Analytics or Tracking by 3rd Party, prohibits Profiling by 2nd and 3rd Party, and prohibits sharing any data with 3rd Party</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#SD-BY-DP"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#SD-BY-AT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#hasFirstParty">
    <skos:prefLabel xml:lang="en">has first party</skos:prefLabel>
    <rdfs:subPropertyOf rdf:resource="https://w3id.org/dpv/owl#hasEntity"/>
    <schema:rangeIncludes rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Person"/>
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <dcam:rangeIncludes rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Person"/>
    <skos:definition xml:lang="en">Specifies the human individual or Person involved as the first party</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/guides">
    <rdf:type rdf:resource="http://www.w3.org/ns/dx/prof/ResourceDescriptor"/>
    <profile:hasRole rdf:resource="http://www.w3.org/ns/dx/prof/role/guidance"/>
    <profile:hasArtifact rdf:resource="https://w3id.org/dpv/guides"/>
    <dct:format rdf:resource="https://www.iana.org/assignments/media-types/text/html"/>
    <dct:title>Guides for Data Privacy Vocabulary</dct:title>
    <dct:conformsTo rdf:resource="https://www.w3.org/TR/html/"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#AgreementNegotiation">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <skos:prefLabel xml:lang="en">Agreement Negotiation</skos:prefLabel>
