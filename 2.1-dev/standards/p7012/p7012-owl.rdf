  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#hasHumanReadableFormat">
    <skos:prefLabel xml:lang="en">has human readable format</skos:prefLabel>
    <schema:rangeIncludes rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dcam:rangeIncludes rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
    <skos:definition xml:lang="en">Indicates the specified resource is a human readable format of the subject</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#hasAgreementRegistry">
    <schema:rangeIncludes rdf:resource="https://w3id.org/dpv/standards/p7012/owl#AgreementRegistry"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:prefLabel xml:lang="en">has agreement registry</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcam:rangeIncludes rdf:resource="https://w3id.org/dpv/standards/p7012/owl#AgreementRegistry"/>
    <skos:definition xml:lang="en">Indicates the inclusion or applicability of the specified Privacy Term Registry</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#hasPortabilityTerm">
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <schema:rangeIncludes rdf:resource="https://w3id.org/dpv/standards/p7012/owl#PortabilityTerm"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <skos:definition xml:lang="en">Relation that associates a Portability Term</skos:definition>
    <skos:prefLabel xml:lang="en">has portability term</skos:prefLabel>
    <dcam:rangeIncludes rdf:resource="https://w3id.org/dpv/standards/p7012/owl#PortabilityTerm"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#AgreementNegotiationCounterOfferMade">
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Status indicating the terms involved in Agreement Negotiation were not accepted and a counter-offer has been made with a different set of terms</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#AgreementNegotiationStatus"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <skos:prefLabel xml:lang="en">Agreement Negotiation Counter Offer Made</skos:prefLabel>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#AgreementNegotiationStatus"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#hasAgentBehaviour">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <skos:prefLabel xml:lang="en">has agent behaviour</skos:prefLabel>
    <dcam:rangeIncludes rdf:resource="https://w3id.org/dpv/standards/p7012/owl#AgentBehaviour"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Relation that indicates the behaviour of Privacy Agents</skos:definition>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <schema:rangeIncludes rdf:resource="https://w3id.org/dpv/standards/p7012/owl#AgentBehaviour"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#Entity">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Organisation"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <skos:definition xml:lang="en">An entity is any organisation with which a person makes or intends to make a contractual agreement, and which is the second party in a contract</skos:definition>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:prefLabel xml:lang="en">Entityi</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#TrackingAllowed">
    <skos:prefLabel xml:lang="en">Tracking Allowed</skos:prefLabel>
    <rdf:value>dpv:Permission</rdf:value>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#TrackingTerm"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Term that indicates Tracking by 2nd and 3rd parties is allowed</skos:definition>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#TrackingTerm"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#ProfilingWithFPDisallowed">
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ProfilingTerm"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <rdf:value>dpv:Prohibition</rdf:value>
    <skos:definition xml:lang="en">Term that indicates Profiling involving use of Fingerprinting is not allowed</skos:definition>
    <skos:prefLabel xml:lang="en">Profiling Disallowed FP</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ProfilingDisallowed"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#TrackingWithPIIDisallowed">
    <skos:prefLabel xml:lang="en">Tracking With PII Disallowed</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#TrackingTerm"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <skos:definition xml:lang="en">Term that indicates Tracking involving use of PII is not allowed</skos:definition>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <rdf:value>dpv:Prohibition</rdf:value>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#TrackingDisallowed"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#SD-BY-ATP-DP">
    <dpv-owl:hasProhibition rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Profiling3PDisallowed"/>
    <dpv-owl:hasProhibition rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Analytics3PDisallowed"/>
    <dpv-owl:hasProhibition rdf:resource="https://w3id.org/dpv/standards/p7012/owl#DataSharingDisallowed"/>
    <dpv-owl:hasProhibition rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Tracking3PDisallowed"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Agreement"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dpv-owl:hasPermission rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Profiling2PAllowed"/>
    <dpv-owl:hasPermission rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Analytics2PAllowed"/>
    <dpv-owl:hasPermission rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Tracking2PAllowed&#10;"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <skos:prefLabel xml:lang="en">SD BY-ATP-DP</skos:prefLabel>
    <dpv-owl:hasObligation rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ServiceDeliveryRequired"/>
    <dpv-owl:hasObligation rdf:resource="https://w3id.org/dpv/standards/p7012/owl#PortabilityRequired"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Term that requires Service Delivery, and permits Analytics, Tracking, or Profiling by the 2nd Party, with an obligation for Data Portability, and prohibits Analytics, Tracking, or Profiling by 3rd Party, and prohibits sharing any data with 3rd Party</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#SD-BY-ATP"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#SD-BY-DP"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#ConflictResolutionTerm">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#ContractualClause"/>
    <skos:prefLabel xml:lang="en">Conflict Resolution Term</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <skos:definition xml:lang="en">Term related to resolving conflicts in Term(s)</skos:definition>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#DataTransparencyOnRequest">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#DataTransparencyTerm"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdf:value>dpv:Obligation</rdf:value>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <skos:prefLabel xml:lang="en">Data Transparency On Request</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Term that indicates transparency regarding data involved and its source is obligated upon request</skos:definition>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#DataTransparencyRequired"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#ServiceDelivery">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#Purpose"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:prefLabel xml:lang="en">Service Delivery</skos:prefLabel>
    <skos:definition xml:lang="en">Purposes associated with delivery of a service</skos:definition>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Purpose"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#AgentAllowsNegotiation">
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#AgentNegotiationBehaviour"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:prefLabel xml:lang="en">Agent Allows Negotiation</skos:prefLabel>
    <skos:definition xml:lang="en">Term that indicates the Agent should allow negotiations</skos:definition>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#AgentNegotiationBehaviour"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#PartyTransparencyExAnte">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#PartyTransparencyTerm"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <skos:prefLabel xml:lang="en">Party Transparency Ex Ante</skos:prefLabel>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdf:value>dpv:Obligation</rdf:value>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Term that indicates transparency regarding identities and involvement of parties in specific roles is obligated ahead of intended process i.e. ex-ante transparency regarding identities and involvement of parties in specific roles</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#PartyTransparencyRequired"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#PurposeTransparencyTerm">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:prefLabel xml:lang="en">Purpose Transparency Term</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <skos:definition xml:lang="en">Term that indicates transparency regarding purposes involved for processing of data and technologies as an obligation</skos:definition>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#ContractualClause"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#ProhibitiveInterpretation">
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#DeonticInterpretationTerm"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">Term that indicates a prohibitive interpretation where if something is not permitted or if there are no rules governing it, then it is assumed to be prohibited</skos:definition>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:prefLabel xml:lang="en">Prohibitive Interpretation</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#DeonticInterpretationTerm"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#TransparencyExAnte">
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <skos:prefLabel xml:lang="en">Transparency Ex Ante</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#TransparencyTerm"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Term that indicates transparency is obligated ahead of intended process i.e. ex-ante transparency</skos:definition>
    <rdf:value>dpv:Obligation</rdf:value>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#TransparencyRequired"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#PartyTransparencyTerm">
    <skos:prefLabel xml:lang="en">Party Transparency Term</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#ContractualClause"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Term that indicates transparency regarding identities and involvement of parties in specific roles as an obligation</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#TrackingTerm">
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <skos:definition xml:lang="en">Term related to Tracking</skos:definition>
    <skos:prefLabel xml:lang="en">Tracking Term</skos:prefLabel>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#ContractualClause"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#AgentAllowsRequestsOnlyPriorAgreementParty">
    <skos:definition xml:lang="en">Term that indicates the Agent should allow requests to be made but only from prior known parties with whom an agreement was established in the past</skos:definition>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#AgentRequestBehaviour"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <skos:prefLabel xml:lang="en">Agent Allows Requests Only Prior Agreement Party</skos:prefLabel>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#AgentAllowsRequestsOnlyKnownParty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#hasSecondParty">
    <rdfs:subPropertyOf rdf:resource="https://w3id.org/dpv/owl#hasEntity"/>
    <skos:definition xml:lang="en">Specifies the entity organisation involved as the second party</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <schema:rangeIncludes rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Entity"/>
    <skos:prefLabel xml:lang="en">has second party</skos:prefLabel>
    <dcam:rangeIncludes rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Entity"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#ResolvePreferringPermission">
    <skos:definition xml:lang="en">Term that indicates a conflict should be resolved by preferring the permission over the prohibition i.e. if something is both prohibited and permitted, it is assumed to be permitted</skos:definition>
    <skos:prefLabel xml:lang="en">Resolve Preferring Permission</skos:prefLabel>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ConflictResolutionTerm"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ConflictResolutionTerm"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#ServiceUsageData">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#PersonalData"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">Data collected, produced, or otherwise generated in the context of using a Service</skos:definition>
    <skos:prefLabel xml:lang="en">Service Usage Data</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#PersonalData"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#AgreementNegotiationPaused">
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:prefLabel xml:lang="en">Agreement Negotiation Paused</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#AgreementNegotiationStatus"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <skos:definition xml:lang="en">Status indicating the Agreement Negotiation has been paused i.e. halted or put on hold without a specific decision</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#AgreementNegotiationStatus"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#DataTransparencyExAnte">
    <skos:prefLabel xml:lang="en">Data Transparency Ex Ante</skos:prefLabel>
    <rdf:value>dpv:Obligation</rdf:value>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#DataTransparencyTerm"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">Term that indicates transparency regarding data involved and its source is obligated ahead of intended process i.e. ex-ante transparency regarding data involved and its source</skos:definition>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#DataTransparencyRequired"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#PermissiveInterpretation">
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#DeonticInterpretationTerm"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Term that indicates a permissive interpretation where if something is not prohibited or if there are no rules governing it, then it is assumed to be permitted</skos:definition>
    <skos:prefLabel xml:lang="en">Permissive Interpretation</skos:prefLabel>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#DeonticInterpretationTerm"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#hasProfilingTerm">
    <schema:rangeIncludes rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ProfilingTerm"/>
    <skos:prefLabel xml:lang="en">has profiling term</skos:prefLabel>
    <skos:definition xml:lang="en">Relation that associates a Profiling Term</skos:definition>
