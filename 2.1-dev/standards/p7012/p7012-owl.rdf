  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#TransparencyTerm">
    <skos:definition xml:lang="en">Term that indicates transparency as an obligation</skos:definition>
    <skos:prefLabel xml:lang="en">Transparency Term</skos:prefLabel>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#ContractualClause"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#AgentAllowsRequests">
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <skos:prefLabel xml:lang="en">Agent Allows Requests</skos:prefLabel>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#AgentRequestBehaviour"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">Term that indicates the Agent should allow requests to be made</skos:definition>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#AgentRequestBehaviour"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#Tracking3PDisallowed">
    <skos:definition xml:lang="en">Term that indicates Tracking 3rd Party is disallowed</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#TrackingTerm"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:prefLabel xml:lang="en">Tracking by 3rd Party Disallowed</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdf:value>dpv:Prohibition</rdf:value>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#TrackingDisallowed"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#PurposeTransparencyExPost">
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#PurposeTransparencyTerm"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <skos:prefLabel xml:lang="en">Purpose Transparency Ex Post</skos:prefLabel>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <skos:definition xml:lang="en">Term that indicates transparency regarding purposes involved for processing of data and technologies is obligated after intended process i.e. ex-post transparency regarding purposes involved for processing of data and technologies</skos:definition>
    <rdf:value>dpv:Obligation</rdf:value>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#PurposeTransparencyRequired"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#ServiceData">
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#PersonalData"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:prefLabel xml:lang="en">Service Data</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <skos:definition xml:lang="en">Data collected, produced, or otherwise generated in the context of a Service</skos:definition>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#PersonalData"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#Person">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#NaturalPerson"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">The human individual or person whose personal data or privacy is involved, and which is the first party in a contract</skos:definition>
    <skos:prefLabel xml:lang="en">Person</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#AgentAllowsNegotiationOnlyKnownParty">
    <skos:prefLabel xml:lang="en">Agent Allows Negotiation Only Known Party</skos:prefLabel>
    <skos:definition xml:lang="en">Term that indicates the Agent should allow negotiations but only from known parties</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#AgentNegotiationBehaviour"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#AgentAllowsNegotiation"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#serialisation-jsonld">
    <dct:conformsTo rdf:resource="https://www.w3.org/TR/json-ld11/"/>
    <dct:format rdf:resource="https://www.iana.org/assignments/media-types/application/ld+json"/>
    <rdf:type rdf:resource="http://www.w3.org/ns/dx/prof/ResourceDescriptor"/>
    <dct:title>Extension for IEEE P7012 - JSON-LD serialiation</dct:title>
    <profile:hasArtifact rdf:resource="https://w3id.org/dpv/standards/p7012/p7012-owl.jsonld"/>
    <profile:hasRole rdf:resource="http://www.w3.org/ns/dx/prof/role/vocabulary"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#PreferenceAlwaysApplies">
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#PreferenceApplicability"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Term that indicates the privacy preference always applies in all contexts and should always be used in agreements and negotiations</skos:definition>
    <skos:prefLabel xml:lang="en">Preference Always Applies</skos:prefLabel>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#PreferenceApplicability"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#PreferenceApplicability">
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <skos:definition xml:lang="en">Term that indicates the applicability of Privacy Preference(s)</skos:definition>
    <skos:prefLabel xml:lang="en">Privacy Preference Applicability</skos:prefLabel>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#ContractualClause"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#Profiling3PDisallowed">
    <skos:definition xml:lang="en">Term that indicates Profiling is not allowed by 3rd Parties</skos:definition>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ProfilingTerm"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <skos:prefLabel xml:lang="en">Profiling Disallowed For Third Party</skos:prefLabel>
    <rdf:value>dpv:Prohibition</rdf:value>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ProfilingDisallowed"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#TransparencyExPost">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#TransparencyTerm"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Term that indicates transparency is obligated after intended process i.e. ex-post transparency</skos:definition>
    <skos:prefLabel xml:lang="en">Transparency Ex Post</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdf:value>dpv:Obligation</rdf:value>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#TransparencyRequired"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#ProfilingWithPIIDisallowed">
    <skos:definition xml:lang="en">Term that indicates Profiling involving use of PII is not allowed</skos:definition>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ProfilingTerm"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdf:value>dpv:Prohibition</rdf:value>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:prefLabel xml:lang="en">Profiling Disallowed PII</skos:prefLabel>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ProfilingDisallowed"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#Agreement">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">A compound set of terms or clauses, proposed and offered before a formal contract between parties, and also referred to as a "proposal" pr "proposed agreement"</skos:definition>
    <skos:prefLabel xml:lang="en">Agreement</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#ContractualClause"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#PDC-AI">
    <skos:prefLabel xml:lang="en">Personal Data Contribution for AI Training and Development</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Agreement"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <skos:definition xml:lang="en">Term that indicates access to data is being provided for the purposes of Training and Operating AI technologies</skos:definition>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#PDC"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#EntityAgent">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <skos:definition xml:lang="en">An Agent that repersents the Entity</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Agent"/>
    <skos:prefLabel xml:lang="en">Entity Agent</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#SharingDataNonAnonymisedDisallowed">
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#DataSharingTerm"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:prefLabel xml:lang="en">Sharing Non-Anonymised Data Disallowed</skos:prefLabel>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdf:value>dpv:Prohibition</rdf:value>
    <skos:definition xml:lang="en">Term that indicates Data Sharing for fully anonymised data is not allowed</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#DataSharingDisallowed"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#hasAgent">
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:subPropertyOf rdf:resource="https://w3id.org/dpv/owl#hasEntity"/>
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <schema:rangeIncludes rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Agent"/>
    <skos:prefLabel xml:lang="en">has agent</skos:prefLabel>
    <dcam:rangeIncludes rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Agent"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <skos:definition xml:lang="en">Specifies the agent that represents a party and can act on behalf</skos:definition>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#TrackingWithFPDisallowed">
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#TrackingTerm"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <skos:prefLabel xml:lang="en">Tracking With FP Disallowed</skos:prefLabel>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdf:value>dpv:Prohibition</rdf:value>
    <skos:definition xml:lang="en">Term that indicates Tracking involving use of Fingerprinting is not allowed</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#TrackingDisallowed"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#AgreementAccepted">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#AgreementNegotiationStatus"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <skos:prefLabel xml:lang="en">Agreement Accepted</skos:prefLabel>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Status indicating the Agreement Negotiation is completed and the parties have accepted the relevant terms</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#AgreementNegotiationStatus"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#ServiceAnalyticsData">
    <skos:definition xml:lang="en">Data collected, produced, or otherwise generated in the context of analysing the usage and provision of a Service</skos:definition>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#PersonalData"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:prefLabel xml:lang="en">Service Analytics Data</skos:prefLabel>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#PersonalData"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#ResolveOnlyWithinContext">
    <skos:definition xml:lang="en">Term that indicates a conflict should be resolved using the specified method but only for this context i.e. other contexts that have their own conflict resolution method should not be overridden</skos:definition>
    <skos:prefLabel xml:lang="en">Resolve Only Within Context</skos:prefLabel>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ConflictResolutionTerm"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ConflictResolutionTerm"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#AgreementInteractionRecord">
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">A record of a interactions conducted in the course of establishing and negotiating agreements, including failed attemps, creation of contracts, and subsequent interactions</skos:definition>
    <skos:prefLabel xml:lang="en">Agreement Interaction Record</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RecordsOfActivities"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#ResolveAcrossContexts">
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ConflictResolutionTerm"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <skos:definition xml:lang="en">Term that indicates this conflict method should be used to resolve all conflicts across contexts i.e. other contexts that have their own conflict resolution method should be overridden</skos:definition>
    <skos:prefLabel xml:lang="en">Resolve Across Contexts</skos:prefLabel>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ConflictResolutionTerm"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#ServiceAnalytics">
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#Purpose"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">Purposes associated with analysing the usage, delivery, and provisioning metrics of a service</skos:definition>
    <skos:prefLabel xml:lang="en">Service Analytics</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Purpose"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#DataTransparencyExPost">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#DataTransparencyTerm"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:prefLabel xml:lang="en">Data Transparency Ex Post</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Term that indicates transparency regarding data involved and its source is obligated after intended process i.e. ex-post transparency regarding data involved and its source</skos:definition>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdf:value>dpv:Obligation</rdf:value>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#DataTransparencyRequired"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#SD-BY-AT">
    <skos:prefLabel xml:lang="en">SD BY-AT</skos:prefLabel>
    <dpv-owl:hasObligation rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ServiceDeliveryRequired"/>
    <dpv-owl:hasPermission rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Analytics2PAllowed"/>
    <dpv-owl:hasPermission rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Tracking2PAllowed"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Agreement"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">Term that requires Service Delivery, and permits Analytics and Tracking by the 2nd Party, and prohibits Analytics, or Tracking by 3rd Party, prohibits Profiling by 2nd and 3rd Party, and prohibits sharing any data with 3rd Party</skos:definition>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dpv-owl:hasProhibition rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Tracking3PDisallowed"/>
    <dpv-owl:hasProhibition rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ProfilingDisallowed"/>
    <dpv-owl:hasProhibition rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Analytics3PDisallowed"/>
    <dpv-owl:hasProhibition rdf:resource="https://w3id.org/dpv/standards/p7012/owl#DataSharingDisallowed"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#SD-BY-A"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#PDC-GOOD">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#Agreement"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">Term that indicates access to data is being provided for the purposes of Public Good</skos:definition>
