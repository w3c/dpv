    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:prefLabel xml:lang="en">Personal Data Contribution for Public Good</skos:prefLabel>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#PDC"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#ResolvePreferringProhibition">
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ConflictResolutionTerm"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">Term that indicates a conflict should be resolved by preferring the prohibition over the permission i.e. if something is both prohibited and permitted, it is assumed to be prohibited</skos:definition>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/standards/p7012/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-12-17</dct:created>
    <skos:prefLabel xml:lang="en">Resolve Preferring Prohibition</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/standards/p7012/owl#ConflictResolutionTerm"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#AgentBehaviour">
    <skos:prefLabel xml:lang="en">Agent Behaviour</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#ContractualClause"/>
