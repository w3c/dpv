    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">Term that indicates transparency regarding data involved and its source is not required to be provided</skos:definition>
    <skos:prefLabel xml:lang="en">Data Transparency Not Required</skos:prefLabel>
