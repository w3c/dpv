  <rdf:Description rdf:about="https://w3id.org/dpv/standards/p7012/owl#PreferenceNeverApplies">
    <skos:prefLabel xml:lang="en">Preference Never Applies</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/standards/p7012/owl#PreferenceApplicability"/>
