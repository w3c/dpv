  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/ai/owl#EngineeringDecisionBias">
    <skos:scopeNote xml:lang="en">Data bias and human cognitive bias can contribute to such bias</skos:scopeNote>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-13</dct:created>
    <dct:contributor>Daniel Doherty</dct:contributor>
    <skos:definition xml:lang="en">Bias that occurs due to machine learning model architectures - encompassing all model specifications, parameters and manually designed features</skos:definition>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/ai/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:prefLabel xml:lang="en">Engineering Decision Bias</skos:prefLabel>
    <rdf:type rdf:resource="https://w3id.org/dpv/risk/owl#RiskConcept"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:source xml:lang="en">ISO/IEC 24027:2021</dct:source>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/ai/owl#AIBias"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/ai/owl#serialisation-html">
    <dct:title>AI Technology Concepts - HTML serialiation</dct:title>
    <profile:hasArtifact rdf:resource="https://w3id.org/dpv/ai/ai-owl.html"/>
    <dct:conformsTo rdf:resource="https://www.w3.org/TR/html/"/>
    <rdf:type rdf:resource="http://www.w3.org/ns/dx/prof/ResourceDescriptor"/>
    <profile:hasRole rdf:resource="http://www.w3.org/ns/dx/prof/role/specification"/>
    <dct:format rdf:resource="https://www.iana.org/assignments/media-types/text/html"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/ai/owl#ModelBias">
    <skos:prefLabel xml:lang="en">Model Bias</skos:prefLabel>
    <rdf:type rdf:resource="https://w3id.org/dpv/risk/owl#RiskConcept"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:source xml:lang="en">ISO/IEC 24027:2021</dct:source>
    <dct:contributor>Daniel Doherty</dct:contributor>
    <skos:definition xml:lang="en">Bias that occurs when ML uses functions like a maximum likelihood estimator to determine parameters, and there is data skew or under-representation present in the data, where the maximum likelihood estimation tends to amplify any underlying bias in the distribution</skos:definition>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-13</dct:created>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/ai/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/ai/owl#EngineeringDecisionBias"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/ai/owl#serialisation-rdf">
    <dct:title>AI Technology Concepts - RDF/XML serialiation</dct:title>
    <dct:format rdf:resource="https://www.iana.org/assignments/media-types/application/rdf+xml"/>
    <profile:hasRole rdf:resource="http://www.w3.org/ns/dx/prof/role/vocabulary"/>
    <profile:hasArtifact rdf:resource="https://w3id.org/dpv/ai/ai-owl.rdf"/>
    <rdf:type rdf:resource="http://www.w3.org/ns/dx/prof/ResourceDescriptor"/>
    <dct:conformsTo rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/ai/owl#Model">
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-05-17</dct:created>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/ai/owl#AI"/>
    <skos:definition xml:lang="en">Physical, mathematical or otherwise logical representation of a system, entity, phenomenon, process or data</skos:definition>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/ai/owl#"/>
    <skos:prefLabel xml:lang="en">Model</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:source xml:lang="en">ISO/IEC 22989:2022</dct:source>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/ai/owl#serialisation-jsonld">
