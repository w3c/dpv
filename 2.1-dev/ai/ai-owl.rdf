    <profile:hasRole rdf:resource="http://www.w3.org/ns/dx/prof/role/vocabulary"/>
    <dct:title>AI Technology Concepts - JSON-LD serialiation</dct:title>
    <dct:format rdf:resource="https://www.iana.org/assignments/media-types/application/ld+json"/>
    <profile:hasArtifact rdf:resource="https://w3id.org/dpv/ai/ai-owl.jsonld"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/ai/owl#ModelExpressivenessBias">
    <dct:contributor>Daniel Doherty</dct:contributor>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/ai/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Bias that occurs from the number and nature of parameters in a model as well as the neural network topology which affect the expressiveness of the model and any feature that affects model expressiveness differently across groups</skos:definition>
    <skos:prefLabel xml:lang="en">Model Expressiveness Bias</skos:prefLabel>
    <rdf:type rdf:resource="https://w3id.org/dpv/risk/owl#RiskConcept"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:source xml:lang="en">ISO/IEC 24027:2021</dct:source>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-13</dct:created>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/ai/owl#ModelInteractionBias"/>
  </rdf:Description>
