  <rdf:Description rdf:about="https://w3id.org/dpv/ai/owl#NonRepresentativeSamplingBias">
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-13</dct:created>
    <rdf:type rdf:resource="https://w3id.org/dpv/risk/owl#RiskConcept"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:contributor>Daniel Doherty</dct:contributor>
    <skos:definition xml:lang="en">Bias that occurs if a dataset is not representative of the intended deployment environment, where the model learns biases based on the ways in which the data is non-representative</skos:definition>
    <skos:prefLabel xml:lang="en">Non-Representative Sampling Bias</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/ai/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:source xml:lang="en">ISO/IEC 24027:2021</dct:source>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/ai/owl#DataBias"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/ai/owl#DataAggregationBias">
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/ai/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Bias that occurs from aggregating data covering different groups of objects that might have different statistical distributions which introduce bias into the data used to train AI systems</skos:definition>
    <skos:prefLabel xml:lang="en">Data Aggregation Bias</skos:prefLabel>
    <rdf:type rdf:resource="https://w3id.org/dpv/risk/owl#RiskConcept"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:source xml:lang="en">ISO/IEC 24027:2021</dct:source>
    <dct:contributor>Daniel Doherty</dct:contributor>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-13</dct:created>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/ai/owl#DataBias"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/ai/owl#ModelInteractionBias">
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-13</dct:created>
    <rdf:type rdf:resource="https://w3id.org/dpv/risk/owl#RiskConcept"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:source xml:lang="en">ISO/IEC 24027:2021</dct:source>
    <dct:contributor>Daniel Doherty</dct:contributor>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/ai/owl#"/>
    <skos:prefLabel xml:lang="en">Model Interaction Bias</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Bias that occurs from the structure of a model to create biased predictions</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/ai/owl#EngineeringDecisionBias"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/ai/owl#AutomationBias">
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/ai/owl#"/>
    <skos:definition xml:lang="en">Bias tha occurs due to propensity for humans to favour suggestions from automated decision-making systems and to ignore contradictory information made without automation, even if it is correct</skos:definition>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:source xml:lang="en">ISO/IEC 24027:2021</dct:source>
    <rdf:type rdf:resource="https://w3id.org/dpv/risk/owl#RiskConcept"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:prefLabel xml:lang="en">Automation Bias</skos:prefLabel>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-13</dct:created>
    <dct:contributor>Daniel Doherty</dct:contributor>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#CognitiveBias"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/ai/owl#HyperparameterTuningBias">
    <dct:contributor>Daniel Doherty</dct:contributor>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-13</dct:created>
    <skos:prefLabel xml:lang="en">Hyperparameter Tuning Bias</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/ai/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Bias that occurs from hyperparameters defining how the model is structured and which cannot be directly trained from the data like model parameters, where hyperparameters affect the model functioning and accuracy of the model</skos:definition>
    <rdf:type rdf:resource="https://w3id.org/dpv/risk/owl#RiskConcept"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:source xml:lang="en">ISO/IEC 24027:2021</dct:source>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/ai/owl#EngineeringDecisionBias"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/ai/owl#MissingFeaturesAndLabelsBias">
    <skos:prefLabel xml:lang="en">Missing Features And Labels Bias</skos:prefLabel>
    <skos:definition xml:lang="en">Bias that occurs when features are missing from individual training samples</skos:definition>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/ai/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdf:type rdf:resource="https://w3id.org/dpv/risk/owl#RiskConcept"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:source xml:lang="en">ISO/IEC 24027:2021</dct:source>
    <skos:scopeNote xml:lang="en">If the frequency of missing features is higher for one group than another then this presents another vector for bias</skos:scopeNote>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-13</dct:created>
    <dct:contributor>Daniel Doherty</dct:contributor>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/ai/owl#DataBias"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/ai/owl#DistributedTrainingBias">
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-13</dct:created>
    <dct:contributor>Daniel Doherty</dct:contributor>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/ai/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Bias that occurs due to distributed machine having different sources of data that do not have the same distribution of feature space</skos:definition>
    <skos:prefLabel xml:lang="en">Distributed Training Bias</skos:prefLabel>
    <rdf:type rdf:resource="https://w3id.org/dpv/risk/owl#RiskConcept"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:source xml:lang="en">ISO/IEC 24027:2021</dct:source>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/ai/owl#DataBias"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/ai/owl#InformativenessBias">
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/ai/owl#"/>
    <skos:definition xml:lang="en">Bias that occurs or some groups, the mapping between inputs present in the data and outputs are more difficult to learn and where a model that only has one feature set available, can be biased against the group whose relationships are difficult to learn from available data</skos:definition>
    <skos:prefLabel xml:lang="en">Informativeness Bias</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdf:type rdf:resource="https://w3id.org/dpv/risk/owl#RiskConcept"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:source xml:lang="en">ISO/IEC 24027:2021</dct:source>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-13</dct:created>
    <skos:scopeNote xml:lang="en">This can happen when some features are highly informative about one group, while a different set of features is highly informative about another group. If this is the case, then a model that only has one feature set available, can be biased against the group whose relationships are difficult to learn from available data</skos:scopeNote>
    <dct:contributor>Daniel Doherty</dct:contributor>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/ai/owl#EngineeringDecisionBias"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/ai/owl#Risk">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Risk"/>
    <skos:prefLabel xml:lang="en">Risk</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">Risk associated with development, use, or operation of AI systems</skos:definition>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/ai/owl#"/>
    <skos:scopeNote xml:lang="en">This concept is a stub</skos:scopeNote>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-28</dct:created>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/ai/owl#FeatureEngineeringBias">
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/ai/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Bias that occurs from steps such as encoding, data type conversion, dimensionality reduction and feature selection which are subject to choices made by the AI developer and introduce bias in the ML model</skos:definition>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-13</dct:created>
    <skos:prefLabel xml:lang="en">Feature Engineering Bias</skos:prefLabel>
    <rdf:type rdf:resource="https://w3id.org/dpv/risk/owl#RiskConcept"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:source xml:lang="en">ISO/IEC 24027:2021</dct:source>
    <dct:contributor>Daniel Doherty</dct:contributor>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/ai/owl#EngineeringDecisionBias"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N6079a7b899404944bba780abc0293aa5">
    <schema:url>https://oecd.ai/en/wonk/ai-system-definition-update</schema:url>
    <rdf:type rdf:resource="https://schema.org/WebPage"/>
    <schema:name>OECD</schema:name>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/ai/owl#AI">
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/ai/owl#"/>
    <skos:prefLabel xml:lang="en">Artificial Intelligence (AI)</skos:prefLabel>
    <skos:scopeNote xml:lang="en">This concept is a stub</skos:scopeNote>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-28</dct:created>
    <dct:source xml:lang="en">ISO/IEC 22989:2022</dct:source>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A technical and scientific field devoted to the engineered system that generates outputs such as content, forecasts, recommendations or decisions for a given set of human-defined objectives</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Technology"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/ai/owl#Technique">
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-28</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:scopeNote xml:lang="en">This concept is a stub</skos:scopeNote>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">Techniques for using or applying AI</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/ai/owl#AI"/>
    <skos:prefLabel xml:lang="en">Technique</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/ai/owl#"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/ai/owl#DataLabelsAndLabellingProcessBias">
    <skos:prefLabel xml:lang="en">Data Labels And Labelling Process Bias</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/ai/owl#"/>
    <skos:definition xml:lang="en">Bias that occurs due to the labelling process itself introducing societal or cognitive biases</skos:definition>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdf:type rdf:resource="https://w3id.org/dpv/risk/owl#RiskConcept"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-13</dct:created>
    <dct:source xml:lang="en">ISO/IEC 24027:2021</dct:source>
    <dct:contributor>Daniel Doherty</dct:contributor>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/ai/owl#DataBias"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/ai/owl#AIBias">
    <rdf:type rdf:resource="https://w3id.org/dpv/risk/owl#RiskConcept"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:prefLabel xml:lang="en">AI Bias</skos:prefLabel>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-18</dct:created>
    <dct:contributor>Daniel Doherty</dct:contributor>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/ai/owl#"/>
    <skos:definition xml:lang="en">Bias associated with development, use, or other activities involving an AI technology or system</skos:definition>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/risk/owl#Bias"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/ai/owl#Measure">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RiskMitigationMeasure"/>
    <skos:scopeNote xml:lang="en">This concept is a stub</skos:scopeNote>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-28</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">Measure to address risk associated with AI Systems</skos:definition>
    <skos:prefLabel xml:lang="en">Measure</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/ai/owl#"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/ai/owl#AISystem">
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/ai/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">OECD 2024 definition: An AI system is a machine-based system that, for explicit or implicit objectives, infers, from the input it receives, how to generate outputs such as predictions, content, recommendations, or decisions that can influence physical or virtual environments. Different AI systems vary in their levels of autonomy and adaptiveness after deployment. ISO/IEC 22989:2023 definition: engineered system that generates outputs such as content, forecasts, recommendations or decisions for a given set of human-defined objectives</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:source rdf:nodeID="N25cb7d09b3f54ffabac2ed2910693e62"/>
    <dct:source rdf:nodeID="N6079a7b899404944bba780abc0293aa5"/>
    <skos:prefLabel xml:lang="en">AI System</skos:prefLabel>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/ai/owl#AI"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-05-17</dct:created>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/ai/owl#AlgorithmSelectionBias">
    <rdf:type rdf:resource="https://w3id.org/dpv/risk/owl#RiskConcept"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:source xml:lang="en">ISO/IEC 24027:2021</dct:source>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-13</dct:created>
    <dct:contributor>Daniel Doherty</dct:contributor>
    <skos:prefLabel xml:lang="en">Algorithm Selection Bias</skos:prefLabel>
    <skos:definition xml:lang="en">Bias that occurs from the selection of machine learning algorithms built into the AI system which introduce unwanted bias in predictions made by the system because the type of algorithm used introduces a variation in the performance of the ML model</skos:definition>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/ai/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/ai/owl#EngineeringDecisionBias"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/ai/owl#serialisation-ttl">
    <profile:hasArtifact rdf:resource="https://w3id.org/dpv/ai/ai-owl.ttl"/>
