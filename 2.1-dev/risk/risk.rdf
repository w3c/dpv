  <rdf:Description rdf:about="https://w3id.org/dpv/risk#DataProcessingBias">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/risk#RiskConcept"/>
    <skos:prefLabel xml:lang="en">Data Processing Bias</skos:prefLabel>
    <skos:definition xml:lang="en">Bias that occurs due to pre-processing (or post-processing) of data, even though the original data would not have led to any bias</skos:definition>
    <skos:broader rdf:resource="https://w3id.org/dpv/risk#DataBias"/>
