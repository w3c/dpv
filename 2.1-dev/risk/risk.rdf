  <rdf:Description rdf:about="https://w3id.org/dpv/risk#SimpsonsParadoxBias">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/risk#RiskConcept"/>
    <skos:prefLabel xml:lang="en">Simpson'S Paradox Bias</skos:prefLabel>
    <skos:definition xml:lang="en">Bias that occurs when a trend that is indicated in individual groups of data reverses when the groups of data are combined</skos:definition>
    <skos:broader rdf:resource="https://w3id.org/dpv/risk#DataBias"/>
    <dct:source xml:lang="en">ISO/IEC 24027:2021</dct:source>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-13</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:contributor>Daniel Doherty</dct:contributor>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/risk#"/>
    <skos:inScheme rdf:resource="https://w3id.org/dpv/risk#bias-classes"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/risk#DataBias">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/risk#RiskConcept"/>
    <skos:prefLabel xml:lang="en">Data Bias</skos:prefLabel>
    <skos:definition xml:lang="en">Bias that occurs when data properties that if unaddressed lead to systems that perform better or worse for different groups</skos:definition>
    <skos:broader rdf:resource="https://w3id.org/dpv/risk#Bias"/>
    <dct:source xml:lang="en">ISO/IEC 24027:2021</dct:source>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-13</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:contributor>Daniel Doherty</dct:contributor>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/risk#"/>
    <skos:inScheme rdf:resource="https://w3id.org/dpv/risk#bias-classes"/>
  </rdf:Description>
