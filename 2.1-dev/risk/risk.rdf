  <rdf:Description rdf:about="https://w3id.org/dpv/risk#PotentialConsequence">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <skos:prefLabel xml:lang="en">Potential Consequence</skos:prefLabel>
    <skos:definition xml:lang="en">Indicates a concept can potentially be a 'consequence concept within an use-case</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv#RiskConcept"/>
    <skos:broader rdf:resource="https://w3id.org/dpv#RiskConcept"/>
    <skos:scopeNote xml:lang="en">A concept being an instance of PotentialConsequence is a suggestion that the concept can be a 'risk' within an use-case - this suggestion is not exclusive and the concept may also be instances of other potential concepts to indicate the multiple possible roles a concept can take. This suggestion can be ignored if it is not applicable to the use-case</skos:scopeNote>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-09-29</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
