  <rdf:Description rdf:about="https://w3id.org/dpv/risk#RuleBasedSystemDesign">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/risk#RiskConcept"/>
    <skos:prefLabel xml:lang="en">Rule-Based System Design</skos:prefLabel>
    <skos:definition xml:lang="en">Bias that occurs due to developer experience and expert advice having a significant influence on rule-based system design</skos:definition>
    <skos:broader rdf:resource="https://w3id.org/dpv/risk#CognitiveBias"/>
    <skos:scopeNote xml:lang="en">Rule based system design also potentially introduces various forms of human cognitive bias</skos:scopeNote>
