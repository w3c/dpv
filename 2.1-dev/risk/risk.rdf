    <skos:prefLabel xml:lang="en">Coverage Bias</skos:prefLabel>
    <skos:definition xml:lang="en">Bias that occurs when a population represented in a dataset does not match the actual or real population that are being used</skos:definition>
    <skos:broader rdf:resource="https://w3id.org/dpv/risk#SelectionBias"/>
