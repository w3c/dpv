    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#DerivedData"/>
    <dct:contributor>Elmar Kiesling; Harshvardhan J. Pandit, Fajar Ekaputra</dct:contributor>
    <skos:prefLabel xml:lang="en">Derived Personal Data</skos:prefLabel>
    <dct:source rdf:nodeID="Nc7c957719ff34ca28ab688e7e76a57ef"/>
    <skos:definition xml:lang="en">Personal Data that is obtained or derived from other data</skos:definition>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2019-05-07</dct:created>
    <skos:scopeNote xml:lang="en">Derived Data is data that is obtained through processing of existing data, e.g. deriving first name from full name. To indicate data that is derived but which was not present or evident within the source data, InferredPersonalData should be used.</skos:scopeNote>
    <skos:related rdf:resource="https://specialprivacy.ercim.eu/vocabs/data#Derived"/>
  </rdf:Description>
