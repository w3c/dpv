  <rdf:Description rdf:about="https://w3id.org/dpv/owl#Pseudonymisation">
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#TechnicalMeasure"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:source rdf:nodeID="N95c188bea2404070ae45cbc6ad552ecd"/>
    <dct:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-11-24</dct:modified>
    <skos:prefLabel xml:lang="en">Pseudonymisation</skos:prefLabel>
    <skos:definition xml:lang="en">Pseudonymisation means the processing of personal data in such a manner that the personal data can no longer be attributed to a specific data subject without the use of additional information, provided that such additional information is kept separately and is subject to technical and organisational measures to ensure that the personal data are not attributed to an identified or identifiable natural person;</skos:definition>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2019-04-05</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:contributor>Axel Polleres, Rob Brennan, Harshvardhan J. Pandit, Mark Lizar, Maya Borges, Damien Desfontaines</dct:contributor>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Deidentification"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#VendorSelectionAssessment">
    <skos:prefLabel xml:lang="en">Vendor Selection Assessment</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#Purpose"/>
