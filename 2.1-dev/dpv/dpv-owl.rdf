    <schema:name>GConsent</schema:name>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#FulfilmentOfObligation">
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-11-09</dct:created>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dct:contributor>Georg P. Krog, Harshvardhan J. Pandit</dct:contributor>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#Purpose"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:prefLabel xml:lang="en">Fulfilment of Obligation</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Purposes associated with carrying out data processing to fulfill an obligation</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Purpose"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#NonCompliant">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#ComplianceStatus"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">State of non-compliance where objectives have not been met, but have not been violated</skos:definition>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-05-18</dct:created>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dct:contributor>Harshvardhan J. Pandit</dct:contributor>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:scopeNote xml:lang="en">Changed from not compliant for consistency in commonly used terms</skos:scopeNote>
    <dct:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-09-07</dct:modified>
    <skos:prefLabel xml:lang="en">Non Compliant</skos:prefLabel>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#ComplianceStatus"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#PrivateInformationRetrieval">
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-08-17</dct:created>
    <dct:contributor>Harshvardhan J. Pandit</dct:contributor>
    <dct:source rdf:nodeID="N0dd4e1ba18d54fec96fb4acfe90da46f"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <skos:prefLabel xml:lang="en">Private Information Retrieval</skos:prefLabel>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#TechnicalMeasure"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">Use of cryptographic methods to retrieve a record from a system without revealing which record is retrieved</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#CryptographicMethods"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#ContractPerformance">
    <dct:contributor>Georg P. Krog, Harshvardhan J. Pandit, Paul Ryan</dct:contributor>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#LegalBasis"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <skos:definition xml:lang="en">Fulfilment or performance of a contract involving specified processing of data or technologies</skos:definition>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-04-07</dct:created>
    <skos:prefLabel xml:lang="en">Contract Performance</skos:prefLabel>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Contract"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#hasInformedStatus">
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <skos:definition xml:lang="en">Indicates whether an entity was informed or uninformed</skos:definition>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <skos:prefLabel xml:lang="en">has informed status</skos:prefLabel>
    <dcam:rangeIncludes rdf:resource="https://w3id.org/dpv/owl#EntityInformedStatus"/>
    <rdfs:subPropertyOf rdf:resource="https://w3id.org/dpv/owl#hasStatus"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-05-10</dct:created>
    <dct:contributor>Harshvardhan J. Pandit</dct:contributor>
    <schema:rangeIncludes rdf:resource="https://w3id.org/dpv/owl#EntityInformedStatus"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#ComplianceStatus">
    <skos:definition xml:lang="en">Status associated with Compliance with some norms, objectives, or requirements</skos:definition>
    <skos:prefLabel xml:lang="en">Compliance Status</skos:prefLabel>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-05-18</dct:created>
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0055"/>
    <dct:contributor>Harshvardhan J. Pandit</dct:contributor>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Status"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#ServiceOptimisation">
    <skos:scopeNote xml:lang="en">Subclass of ServiceProvision since optimisation is usually considered part of providing services</skos:scopeNote>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#Purpose"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:prefLabel xml:lang="en">Service Optimisation</skos:prefLabel>
    <skos:definition xml:lang="en">Purposes associated with optimisation of services or activities</skos:definition>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2019-04-05</dct:created>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dct:contributor>Harshvardhan J. Pandit, Javier Fernández, Axel Polleres, Elmar Kiesling, Fajar Ekaputra, Simon Steyskal</dct:contributor>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#ServiceProvision"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#IdentityVerification">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#Purpose"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Purposes associated with verifying or authenticating identity as a form of security</skos:definition>
    <skos:prefLabel xml:lang="en">Identity Verification</skos:prefLabel>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2019-04-05</dct:created>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dct:contributor>Harshvardhan J. Pandit, Javier Fernández, Axel Polleres, Elmar Kiesling, Fajar Ekaputra, Simon Steyskal</dct:contributor>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Verification"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#ProcessingScale">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-09-07</dct:created>
    <skos:prefLabel xml:lang="en">Processing Scale</skos:prefLabel>
    <skos:scopeNote xml:lang="en">The exact definition of what constitutes "scale" depends on use of jurisdictional, domain-specific, or other forms of externally defined criterias. Where possible, this should be reflected by extending the scales provided with the appropriate context.</skos:scopeNote>
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0049"/>
    <dct:contributor>Harshvardhan J. Pandit, Piero Bonatti</dct:contributor>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Scale"/>
    <skos:definition xml:lang="en">Scale of Processing</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#SecurityIncidentRecord">
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#OrganisationalMeasure"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">Record of a security incident</skos:definition>
