  <rdf:Description rdf:about="https://w3id.org/dpv/owl#LocationLocality">
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Locality refers to whether the specified location is local within some context, e.g. for the user</skos:definition>
