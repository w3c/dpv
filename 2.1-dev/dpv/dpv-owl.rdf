    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <skos:prefLabel xml:lang="en">Inferred Personal Data</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Inferred Data is derived data generated from existing data, but which did not originally exist within it, e.g. inferring demographics from browsing history.</skos:scopeNote>
    <dct:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2023-12-10</dct:modified>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-01-19</dct:created>
