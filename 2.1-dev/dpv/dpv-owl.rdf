    <dct:contributor>Harshvardhan J. Pandit, Georg P. Krog, Julian Flake, Paul Ryan, Beatriz Esteves</dct:contributor>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#DataSubject"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#ActivityStatus">
    <skos:definition xml:lang="en">Status associated with activity operations and lifecycles</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
