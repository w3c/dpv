    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Customer"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#hasRepresentative">
    <dcam:rangeIncludes rdf:resource="https://w3id.org/dpv/owl#Representative"/>
    <rdfs:subPropertyOf rdf:resource="https://w3id.org/dpv/owl#hasEntity"/>
