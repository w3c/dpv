    <dct:contributor>Beatriz Esteves</dct:contributor>
    <dct:source xml:lang="en">DGA 2.20</dct:source>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#Processing"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
