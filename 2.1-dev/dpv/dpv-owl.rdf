    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-09-01</dct:created>
    <skos:definition xml:lang="en">Purposes associated with managing selection, assessment, and evaluation related to vendors</skos:definition>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:contributor>Paul Ryan, Georg P. Krog, David Hickey, Harshvardhan J. Pandit</dct:contributor>
    <dct:source rdf:nodeID="N4ff6a16974db491da8f8eea478aafb0d"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#VendorManagement"/>
  </rdf:Description>
