    <skos:prefLabel xml:lang="en">Regulatory Sandbox</skos:prefLabel>
    <dct:contributor>Harshvardhan J. Pandit</dct:contributor>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-05-17</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Safeguard"/>
  </rdf:Description>
