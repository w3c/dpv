  <rdf:Description rdf:about="https://w3id.org/dpv/owl#PartialAutomation">
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#AutomationLevel"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:contributor>Harshvardhan J. Pandit, Delaram Golpayegani</dct:contributor>
    <skos:scopeNote xml:lang="en">Human Involvement is implied here, specifically the ability to Control operations, but also possibly for intervention, oversight, and verification</skos:scopeNote>
    <skos:prefLabel xml:lang="en">Partial Automation</skos:prefLabel>
    <dct:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-20</dct:modified>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2023-12-10</dct:created>
    <skos:definition xml:lang="en">Level of automation corresponding to Level 2 in ISO/IEC 22989:2022 where the automation is present in multiple parts of the system or in a manner that does not require the human to control/use these parts while still retaining control over the system</skos:definition>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dct:source rdf:nodeID="N3d268de69e934a80a0dea0e1d5f1ecb1"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#AutomationLevel"/>
  </rdf:Description>
