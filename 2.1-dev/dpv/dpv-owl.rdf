    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Assessment regarding legal compliance</skos:definition>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-14</dct:created>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dct:contributor>Harshvardhan J. Pandit, Georg P. Krog</dct:contributor>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#ComplianceAssessment"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#MonotonicCounterPseudonymisation">
    <skos:definition xml:lang="en">A simple pseudonymisation method where identifiers are substituted by a number chosen by a monotonic counter</skos:definition>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#TechnicalMeasure"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:prefLabel xml:lang="en">Monotonic Counter Pseudonymisation</skos:prefLabel>
    <dct:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-10-13</dct:modified>
    <dct:contributor>Harshvardhan J. Pandit</dct:contributor>
    <dct:source rdf:nodeID="N3938bf64bb6445cc8ae01ee17540b6b4"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-08-17</dct:created>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Pseudonymisation"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#Risk">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2020-11-18</dct:created>
    <skos:scopeNote xml:lang="en">Risks can be associated with one or more different concepts such as purpose, processing, personal data, technical or organisational measure</skos:scopeNote>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RiskConcept"/>
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0071"/>
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0027"/>
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0068"/>
    <skos:prefLabel xml:lang="en">Risk</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">A risk or possibility or uncertainty of negative effects, impacts, or consequences</skos:definition>
    <dct:contributor>Harshvardhan J. Pandit</dct:contributor>
    <dct:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-08-16</dct:modified>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#LicenseAgreement">
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-08-27</dct:created>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#LegalBasis"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A Legal Document providing permission to utilise data or resource and outlining the conditions under which such use is considered valid</skos:definition>
    <skos:prefLabel xml:lang="en">License Agreement</skos:prefLabel>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Contract"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#ProvideOfficialStatistics">
    <dct:source xml:lang="en">DGA 2.16</dct:source>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#Purpose"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <skos:prefLabel xml:lang="en">Provide Official Statistics</skos:prefLabel>
    <skos:definition xml:lang="en">Purposes associated with facilitating the development, production and dissemination of reliable official statistics</skos:definition>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-02-14</dct:created>
    <dct:contributor>Beatriz Esteves, Harshvardhan J. Pandit</dct:contributor>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#PublicBenefit"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#SensitivePersonalData">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#PersonalData"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#SensitiveData"/>
    <skos:scopeNote xml:lang="en">Sensitivity' is a matter of context, and may be defined within legal frameworks. For GDPR, Special categories of personal data are considered a subset of sensitive data. To illustrate the difference between the two, consider the situation where Location data is collected, and which is considered 'sensitive' but not 'special'. As a probable rule, sensitive data require additional considerations whereas special category data requires additional legal basis / justifications.</skos:scopeNote>
    <skos:prefLabel xml:lang="en">Sensitive Personal Data</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:contributor>Harshvardhan J. Pandit</dct:contributor>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-01-19</dct:created>
    <skos:definition xml:lang="en">Personal data that is considered 'sensitive' in terms of privacy and/or impact, and therefore requires additional considerations and/or protection</skos:definition>
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0045"/>
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0010"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#PublicBenefit">
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:prefLabel xml:lang="en">Public Benefit</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#Purpose"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">Purposes undertaken and intended to provide benefit to public or society</skos:definition>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-02-14</dct:created>
    <dct:contributor>Harshvardhan J. Pandit</dct:contributor>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Purpose"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#ChallengingProcessOutput">
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:scopeNote xml:lang="en">Challenge refers to raising questions about validity, necessity, correctness, or other similar 'trustworthiness' attributes regarding the output of the process or plan or implementation (where output is distinct from the process itself)</skos:scopeNote>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-05-11</dct:created>
    <skos:definition xml:lang="en">Involvement where entity can challenge the output of specified context</skos:definition>
    <dct:contributor>Harshvardhan J. Pandit, Delaram Golpayegani, Steve Hickman</dct:contributor>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#EntityPermissiveInvolvement"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <skos:prefLabel xml:lang="en">Challenging Process Output</skos:prefLabel>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#EntityPermissiveInvolvement"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#LegitimateInterestOfController">
    <skos:prefLabel xml:lang="en">Legitimate Interest of Controller</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#LegalBasis"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">Legitimate Interests of a Data Controller in conducting specified activities</skos:definition>
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0065"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:contributor>Georg P. Krog, Harshvardhan J. Pandit, Paul Ryan</dct:contributor>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-05-19</dct:created>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#LegitimateInterest"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#EducationalTraining">
    <dct:contributor>Harshvardhan J. Pandit</dct:contributor>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#OrganisationalMeasure"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:source rdf:nodeID="N8df28cc87fb84cc596ce1e291fdceb46"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <skos:definition xml:lang="en">Training methods that are intended to provide education on topic(s)</skos:definition>
    <skos:prefLabel xml:lang="en">Educational Training</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-08-17</dct:created>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#StaffTraining"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#SensitivityLevel">
    <skos:definition xml:lang="en">Sensitivity' reflects the risk of impact if not secured or utilised with appropriate measures and controls e.g. for sensitive data</skos:definition>
    <skos:scopeNote xml:lang="en">ISO/IEC TS 38505-3:2021 defines 'data sensitivity' as the potential harm of unauthorised disclosure. DPV's use of the concept goes beyond disclosure as it refers to the level of safeguards or controls the data requires as a reflection of its 'sensitive' nature. To indicate quantified levels of sensitivity, e.g. "high sensitivity", instances of severity can be directly used or specialised</skos:scopeNote>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2023-08-24</dct:created>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Severity"/>
    <dct:contributor>Harshvardhan J. Pandit</dct:contributor>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:prefLabel xml:lang="en">Sensitivity Level</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#Visitor">
    <skos:definition xml:lang="en">Data subjects that are temporary visitors</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#DataSubject"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
