  <rdf:Description rdf:about="https://w3id.org/dpv/owl#SubProcessorAgreement">
    <skos:prefLabel xml:lang="en">Sub-Processor Agreement</skos:prefLabel>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#LegalMeasure"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#LegalBasis"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dct:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-08-27</dct:modified>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-01-26</dct:created>
    <dct:contributor>Georg P. Krog, Harshvardhan J. Pandit, Beatriz Esteves, Paul Ryan, Julian Flake</dct:contributor>
    <skos:definition xml:lang="en">An agreement outlining conditions, criteria, obligations, responsibilities, and specifics for carrying out processing of data between a Data Processor and a Data (Sub-)Processor</skos:definition>
    <sw:term_status xml:lang="en">modified</sw:term_status>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#DataProcessingAgreement"/>
  </rdf:Description>
