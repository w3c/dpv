    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">Policy regarding storage of data, including the manner, duration, location, and conditions for storage</skos:definition>
    <dct:contributor>Georg P. Krog, Harshvardhan J. Pandit</dct:contributor>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#DataProcessingPolicy"/>
  </rdf:Description>
