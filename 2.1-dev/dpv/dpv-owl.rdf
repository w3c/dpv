    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Contract"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#NotRequired">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#Necessity"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">Indication of neither being required nor optional i.e. not relevant or needed</skos:definition>
