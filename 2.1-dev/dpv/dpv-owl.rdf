  <rdf:Description rdf:about="https://w3id.org/dpv/owl#InferredPersonalData">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#InferredData"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#DerivedPersonalData"/>
    <skos:definition xml:lang="en">Personal Data that is obtained through inference from other data</skos:definition>
    <dct:contributor>Harshvardhan J. Pandit</dct:contributor>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
