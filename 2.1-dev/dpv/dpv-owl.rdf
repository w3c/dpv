    <dcam:rangeIncludes rdf:resource="https://w3id.org/dpv/owl#ConsentControl"/>
    <skos:definition xml:lang="en">Specific a control associated with consent</skos:definition>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-05-11</dct:created>
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
