  <rdf:Description rdf:about="https://w3id.org/dpv/owl#ProvidedPersonalData">
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0046"/>
    <skos:definition xml:lang="en">Personal Data that has been provided by an entity such as the Data Subject</skos:definition>
    <dct:contributor>Harshvardhan J. Pandit, Paul Ryan</dct:contributor>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
