  <rdf:Description rdf:about="https://w3id.org/dpv/owl#Share">
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#Processing"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:prefLabel xml:lang="en">Share</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2019-05-07</dct:created>
    <skos:definition xml:lang="en">to give data (or a portion of it) to others</skos:definition>
    <dct:source rdf:nodeID="Nfd2ff859a14a490281eed4fe08c6e4cd"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Disclose"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#ExplicitlyExpressedConsent">
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0018"/>
    <skos:prefLabel xml:lang="en">Explicitly Expressed Consent</skos:prefLabel>
    <dct:contributor>Georg P. Krog, Harshvardhan J. Pandit, Paul Ryan, Julian Flake</dct:contributor>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#LegalBasis"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-06-21</dct:created>
    <skos:definition xml:lang="en">Consent that is expressed through an explicit action solely conveying a consenting decision</skos:definition>
    <skos:scopeNote xml:lang="en">Explicitly expressed consent is a more specific form of Expressed consent where the action taken must 'explicitly' relate to only the consent decision. Expressed consent where the consenting is part of other matters therefore cannot satisfy the requirements of explicitly expressed consent. An example of explicit action expressing the consenting decision is a button on a web form where the form only relates to consent, or it is accompanied with suitable text that reiterates what the consenting decision is about</skos:scopeNote>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#ExpressedConsent"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#OrganisationRiskManagement">
