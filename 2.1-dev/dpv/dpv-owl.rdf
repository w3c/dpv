    <dct:contributor>Harshvardhan J. Pandit, Delaram Golpayegani, Steve Hickman</dct:contributor>
    <skos:definition xml:lang="en">Involvement where entity cannot challenge input of specified context</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#EntityNonPermissiveInvolvement"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#SecretSharingSchemes">
    <skos:definition xml:lang="en">Use of secret sharing schemes where the secret can only be reconstructed through combination of sufficient number of individuals</skos:definition>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-08-17</dct:created>
    <dct:source rdf:nodeID="N38fc9979890145f29aeb05717222b684"/>
