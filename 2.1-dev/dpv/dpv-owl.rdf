    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <skos:definition xml:lang="en">Scale of data subjects considered sporadic or sparse within the context</skos:definition>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#DataSubjectScale"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
