    <dct:contributor>Harshvardhan J. Pandit, Paul Ryan, Georg P. Krog, Julian Flake, Beatriz Esteves</dct:contributor>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Necessity"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#ObservedData">
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#CollectedData"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
