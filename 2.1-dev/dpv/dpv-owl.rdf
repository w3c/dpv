    <dct:source rdf:nodeID="N3ca21ddbecf94e1c9237e64ada4ada92"/>
    <skos:prefLabel xml:lang="en">End-to-End Encryption (E2EE)</skos:prefLabel>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#TechnicalMeasure"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">Encrypted communications where data is encrypted by the sender and decrypted by the intended receiver to prevent access to any third party</skos:definition>
