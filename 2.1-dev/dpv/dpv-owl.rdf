  <rdf:Description rdf:about="https://w3id.org/dpv/owl#Infer">
    <dct:contributor>Harshvardhan J. Pandit</dct:contributor>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-04-20</dct:created>
    <dct:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-10-14</dct:modified>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <skos:definition xml:lang="en">to infer data from existing data</skos:definition>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#Processing"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:scopeNote xml:lang="en">Infer indicates data that is derived without it being present or obtainable from existing data. For data that is presented, and is 'extracted' or 'obtained' from existing data, see Derive.</skos:scopeNote>
    <skos:prefLabel xml:lang="en">Infer</skos:prefLabel>
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0009"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Derive"/>
  </rdf:Description>
