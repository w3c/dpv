    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#FeeRequirement"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <skos:definition xml:lang="en">Concept indicating a fee is required. The value of the fee should be specified using rdf:value or an another relevant means</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N29d3818f245d4ffcbadae308b76fdff2">
    <schema:url>https://www.enisa.europa.eu/publications/reference-incident-classification-taxonomy/</schema:url>
