    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#CryptographicMethods"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#Anonymise">
    <skos:prefLabel xml:lang="en">Anonymise</skos:prefLabel>
    <dct:source rdf:nodeID="N9ad56c5f7ccd4130ac5bc3bab4a54b31"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#Processing"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">to irreversibly alter personal data in such a way that an unique data subject can no longer be identified directly or indirectly or in combination with other data</skos:definition>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2019-05-07</dct:created>
    <skos:related rdf:resource="https://specialprivacy.ercim.eu/vocabs/processing#Anonymise"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Transform"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#InternationalOrganisation">
    <dct:contributor>Julian Flake, Georg P. Krog</dct:contributor>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dct:source rdf:nodeID="N9487780657314457a93129d62751b909"/>
    <skos:prefLabel xml:lang="en">International Organisation</skos:prefLabel>
    <skos:definition xml:lang="en">An organisation and its subordinate bodies governed by public international law, or any other body which is set up by, or on the basis of, an agreement between two or more countries</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2020-10-05</dct:modified>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Organisation"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-03-23</dct:created>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#Lawfulness">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:contributor>Harshvardhan J. Pandit</dct:contributor>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:prefLabel xml:lang="en">Lawfulness</skos:prefLabel>
