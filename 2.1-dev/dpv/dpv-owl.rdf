  <rdf:Description rdf:about="https://w3id.org/dpv/owl#hasEntityInvolvement">
    <schema:rangeIncludes rdf:resource="https://w3id.org/dpv/owl#EntityInvolvement"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <skos:prefLabel xml:lang="en">has entity involvement</skos:prefLabel>
    <skos:definition xml:lang="en">Indicates involvement of an entity in specified context</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
