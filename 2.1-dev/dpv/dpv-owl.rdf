  <rdf:Description rdf:about="https://w3id.org/dpv/owl#DerivedPersonalData">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2023-12-10</dct:modified>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0009"/>
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0046"/>
