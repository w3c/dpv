  <rdf:Description rdf:about="https://w3id.org/dpv/owl#PassivelyInvolved">
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-05-10</dct:created>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#InvolvementStatus"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:prefLabel xml:lang="en">Passively Involved</skos:prefLabel>
    <dct:contributor>Harshvardhan J. Pandit, Delaram Golpayegani, Georg P. Krog, Paul Ryan</dct:contributor>
    <skos:scopeNote xml:lang="en">An example of passive involvement is a person being monitored by a CCTV</skos:scopeNote>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <skos:definition xml:lang="en">Status indicating the specified context is 'passively' involved</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#InvolvementStatus"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#ComplianceViolation">
