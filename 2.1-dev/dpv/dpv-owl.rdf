  <rdf:Description rdf:about="https://w3id.org/dpv/owl#DataReusePolicy">
    <skos:definition xml:lang="en">Policy regarding reuse of data i.e. using data for purposes other than its initial purpose</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#OrganisationalMeasure"/>
