    <skos:definition xml:lang="en">Indicate the measure is required for meeting specified requirement or satisfying specified condition/constraint</skos:definition>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-14</dct:created>
    <dcam:domainIncludes rdf:resource="https://w3id.org/dpv/owl#TechnicalOrganisationalMeasure"/>
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </rdf:Description>
