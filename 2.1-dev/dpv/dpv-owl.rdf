    <skos:prefLabel xml:lang="en">Observed Data</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#isIndicatedBy">
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Specifies entity who indicates the specific context</skos:definition>
    <schema:rangeIncludes rdf:resource="https://w3id.org/dpv/owl#Entity"/>
