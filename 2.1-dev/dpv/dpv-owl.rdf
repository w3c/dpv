  <rdf:Description rdf:about="https://w3id.org/dpv/owl#DataProcessorContract">
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <skos:definition xml:lang="en">Creation, completion, fulfilment, or performance of a contract, with the Data Controller and Data Processor as parties, and involving specified processing of data or technologies</skos:definition>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2023-12-10</dct:created>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#LegalBasis"/>
