    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:scopeNote xml:lang="en">Advertising is a subset of Marketing. Advertising by itself does not indicate 'personalisation' i.e. personalised ads.</skos:scopeNote>
