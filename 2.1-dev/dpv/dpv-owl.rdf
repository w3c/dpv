    <skos:prefLabel xml:lang="en">Sporadic Scale Of Data Subjects</skos:prefLabel>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#DataSubjectScale"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#ConsentGiven">
    <dct:source rdf:nodeID="N01277b264af740ee954021bbec7e468c"/>
    <skos:definition xml:lang="en">The state where consent has been given</skos:definition>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-06-22</dct:created>
    <dct:contributor>Georg P. Krog, Harshvardhan J. Pandit, Paul Ryan, Julian Flake</dct:contributor>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#ConsentStatus"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:prefLabel xml:lang="en">Consent Given</skos:prefLabel>
    <skos:scopeNote xml:lang="en">An example of this state is when the individual clicks on a button, ticks a checkbox, verbally agrees - or any other form that communicates their decision agreeing to the processing of data</skos:scopeNote>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#ConsentStatusValidForProcessing"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#AccountManagement">
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#Purpose"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:contributor>Georg P. Krog, Harshvardhan J. Pandit, Beatriz Esteves</dct:contributor>
    <skos:definition xml:lang="en">Account Management refers to purposes associated with account management, such as to create, provide, maintain, and manage accounts</skos:definition>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-09-08</dct:created>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <skos:prefLabel xml:lang="en">Account Management</skos:prefLabel>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Purpose"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#ConsequenceOfSuccess">
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-03-23</dct:created>
    <skos:prefLabel xml:lang="en">Consequence of Success</skos:prefLabel>
    <dct:contributor>Harshvardhan J. Pandit, Georg P. Krog</dct:contributor>
    <skos:definition xml:lang="en">The consequence(s) possible or arising from success of specified context</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Consequence"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#Rule">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:contributor>Harshvardhan J. Pandit, Georg P. Krog, Beatriz Esteves, Paul Ryan</dct:contributor>
    <skos:definition xml:lang="en">A rule describing a process or control that directs or determines if and how an activity should be conducted</skos:definition>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-10-19</dct:created>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <skos:prefLabel xml:lang="en">Rule</skos:prefLabel>
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0030"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#AssistiveAutomation">
    <skos:scopeNote xml:lang="en">Human Involvement is implied here, specifically the ability to make decisions regarding operations, but also possibly for intervention, oversight, and verification</skos:scopeNote>
    <dct:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-20</dct:modified>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <skos:definition xml:lang="en">Level of automation corresponding to Level 1 in ISO/IEC 22989:2022 where automation is limited to parts of the system or a specific part of the system in a manner that does not change the control of the human in using/driving the system</skos:definition>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#AutomationLevel"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2023-12-10</dct:created>
    <skos:prefLabel xml:lang="en">Assistive Automation</skos:prefLabel>
    <dct:contributor>Harshvardhan J. Pandit, Delaram Golpayegani</dct:contributor>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:source rdf:nodeID="N21017ab6e847489d9fb6549c9dc3fcf3"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#AutomationLevel"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#PrivacyByDesign">
    <skos:prefLabel xml:lang="en">Privacy by Design</skos:prefLabel>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#OrganisationalMeasure"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">Practices regarding incorporating data protection and privacy in the design of information and services (synonymous with Data Protection by Design)</skos:definition>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2019-04-05</dct:created>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dct:contributor>Axel Polleres, Rob Brennan, Harshvardhan J. Pandit, Mark Lizar</dct:contributor>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#GuidelinesPrinciple"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#RiskMitigationMeasure">
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:prefLabel xml:lang="en">Risk Mitigation Measure</skos:prefLabel>
    <dct:contributor>Georg P. Krog, Harshvardhan J. Pandit, Paul Ryan</dct:contributor>
    <skos:definition xml:lang="en">Measures intended to mitigate, minimise, or prevent risk.</skos:definition>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2020-11-04</dct:created>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#TechnicalOrganisationalMeasure"/>
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0068"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#hasPermission">
    <rdfs:subPropertyOf rdf:resource="https://w3id.org/dpv/owl#hasRule"/>
    <skos:prefLabel xml:lang="en">has permission</skos:prefLabel>
    <schema:domainIncludes rdf:resource="https://w3id.org/dpv/owl#Context"/>
    <dcam:domainIncludes rdf:resource="https://w3id.org/dpv/owl#Context"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <schema:rangeIncludes rdf:resource="https://w3id.org/dpv/owl#Permission"/>
