  <rdf:Description rdf:about="https://w3id.org/dpv/owl#ImpliedConsent">
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#LegalBasis"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">Consent that is implied indirectly through an action not associated solely with conveying a consenting decision</skos:definition>
    <skos:prefLabel xml:lang="en">Implied Consent</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Implied consent is expected to also be Informed Consent. An example is a CCTV notice outside a monitored area that informs the individuals that by walking in they would be consenting to the use of camera for surveillance.</skos:scopeNote>
    <dct:contributor>Georg P. Krog, Harshvardhan J. Pandit, Paul Ryan, Julian Flake</dct:contributor>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-06-21</dct:created>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#InformedConsent"/>
  </rdf:Description>
