  <rdf:Description rdf:about="https://w3id.org/dpv/owl#HumanInvolvementForDecision">
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#HumanInvolvement"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-09-06</dct:created>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <skos:prefLabel xml:lang="en">Human Involvement for decision</skos:prefLabel>
    <skos:definition xml:lang="en">Human involvement for the purposes of exercising decisions over the specified operations in context</skos:definition>
    <skos:scopeNote xml:lang="en">Decisions are about exercising control over the operation, and are distinct from input (data or parameters).</skos:scopeNote>
    <dct:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2023-12-10</dct:modified>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#HumanInvolvement"/>
  </rdf:Description>
