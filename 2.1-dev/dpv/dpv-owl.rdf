  <rdf:Description rdf:about="https://w3id.org/dpv/owl#GeneratedData">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Data"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <skos:prefLabel xml:lang="en">Generated Data</skos:prefLabel>
    <skos:definition xml:lang="en">Data that is generated or brought into existence without relation to existing data i.e. it is not derived or inferred from other data</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
