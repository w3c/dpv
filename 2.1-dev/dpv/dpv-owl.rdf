    <dct:source xml:lang="en">NIST SP 800-171</dct:source>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#PhysicalMeasure"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#CustomerSolvencyMonitoring">
    <skos:definition xml:lang="en">Customer Solvency Monitoring refers to purposes associated with monitor solvency of customers for financial diligence</skos:definition>
    <dct:source rdf:nodeID="N31fca7959d9044d6aa6690ca233915ae"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
