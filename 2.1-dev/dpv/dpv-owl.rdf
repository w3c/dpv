    <rdf:type rdf:resource="https://w3id.org/dpv/owl#InvolvementStatus"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:scopeNote xml:lang="en">An example of active involvement is a person directly using a system to enter information</skos:scopeNote>
    <skos:prefLabel xml:lang="en">Actively Involved</skos:prefLabel>
    <skos:definition xml:lang="en">Status indicating the specified context is 'actively' involved</skos:definition>
