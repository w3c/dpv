    <skos:prefLabel xml:lang="en">Data Redaction</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#DataSanitisationTechnique"/>
