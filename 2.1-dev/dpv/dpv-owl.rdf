  <rdf:Description rdf:about="https://w3id.org/dpv/owl#hasAlgorithmicLogic">
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dct:contributor>Georg P. Krog, Paul Ryan, Harshvardhan J. Pandit</dct:contributor>
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcam:rangeIncludes rdf:resource="https://w3id.org/dpv/owl#AlgorithmicLogic"/>
    <skos:prefLabel xml:lang="en">has algorithmic logic</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-06-15</dct:modified>
    <schema:rangeIncludes rdf:resource="https://w3id.org/dpv/owl#AlgorithmicLogic"/>
