    <dct:contributor>Harshvardhan J. Pandit</dct:contributor>
    <skos:scopeNote xml:lang="en">This policy can be used to describe the procedures associated with undertaking such reuse of data, for example to assess its legality and the compatibility of the initial and subsequent purposes</skos:scopeNote>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#DataProcessingPolicy"/>
  </rdf:Description>
