    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#CollectedPersonalData"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#ProvidedData"/>
    <skos:scopeNote xml:lang="en">Provided personal data involves one entity (e.g. data subject) explicitly providing the data, which the other entity (e.g. data controller) then collects</skos:scopeNote>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
  </rdf:Description>
