  <rdf:Description rdf:about="https://w3id.org/dpv/owl#Necessity">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Context"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:prefLabel xml:lang="en">Necessity</skos:prefLabel>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-02-12</dct:created>
    <skos:definition xml:lang="en">An indication of 'necessity' within a context</skos:definition>
    <dct:contributor>Harshvardhan J. Pandit, Paul Ryan, Georg P. Krog, Julian Flake, Beatriz Esteves</dct:contributor>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0052"/>
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0026"/>
    <skos:scopeNote xml:lang="en">Necessity can be used to express need, essentiality, requirement, or compulsion.</skos:scopeNote>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#ThirdCountry">
