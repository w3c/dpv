  <rdf:Description rdf:about="https://w3id.org/dpv/owl#NotificationStatus">
    <skos:definition xml:lang="en">Status indicating whether notification(s) are planned, completed, or failed</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-05-19</dct:created>
