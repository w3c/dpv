  <rdf:Description rdf:about="https://w3id.org/dpv/owl#CorrectingProcess">
    <skos:scopeNote xml:lang="en">Correction of process refers to the ability to change how the process takes place</skos:scopeNote>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:prefLabel xml:lang="en">Correcting Process</skos:prefLabel>
    <skos:definition xml:lang="en">Involvement where entity can correct the process of specified context</skos:definition>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-05-11</dct:created>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
