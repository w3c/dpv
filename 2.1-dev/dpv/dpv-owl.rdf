  <rdf:Description rdf:about="https://w3id.org/dpv/owl#GeographicCoverage">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Scale"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-06-15</dct:created>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
