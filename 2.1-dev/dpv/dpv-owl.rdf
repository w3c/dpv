  <rdf:Description rdf:about="https://w3id.org/dpv/owl#Anonymisation">
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#TechnicalMeasure"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <skos:prefLabel xml:lang="en">Anonymisation</skos:prefLabel>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2019-04-05</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Anonymisation is the process by which data is irreversibly altered in such a way that a data subject can no longer be identified directly or indirectly, either by the entity holding the data alone or in collaboration with other entities and information sources</skos:definition>
    <dct:contributor>Axel Polleres, Rob Brennan, Harshvardhan J. Pandit, Mark Lizar, Maya Borges, Damien Desfontaines</dct:contributor>
    <dct:source rdf:nodeID="N00e7b95686e54ad0ae1b9d9596a840ec"/>
    <dct:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-11-24</dct:modified>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Deidentification"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#OrganisationGovernance">
    <skos:prefLabel xml:lang="en">Organisation Governance</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dct:source rdf:nodeID="N2a237a65f26f4e1f8934c56621ff475c"/>
