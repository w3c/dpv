    <dct:contributor>Harshvardhan J. Pandit</dct:contributor>
    <skos:prefLabel xml:lang="en">Security Incident Record</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RecordsOfActivities"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#hasNecessity">
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-13</dct:created>
    <dct:contributor>Harshvardhan J. Pandit</dct:contributor>
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcam:rangeIncludes rdf:resource="https://w3id.org/dpv/owl#Necessity"/>
    <skos:definition xml:lang="en">Indicates the necessity for specified context or criteria</skos:definition>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:prefLabel xml:lang="en">has necessity</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0052"/>
    <schema:rangeIncludes rdf:resource="https://w3id.org/dpv/owl#Necessity"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#Right">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2020-11-18</dct:created>
    <skos:scopeNote xml:lang="en">A 'right' is a legal, social, or ethical principle of freedom or entitlement which dictate the norms regarding what is allowed or owed. Rights as a concept encompass a broad area of norms and entities, and are not specific to Individuals or Data Protection / Privacy. For individual specific rights, see dpv:DataSubjectRight</skos:scopeNote>
    <skos:definition xml:lang="en">The right(s) applicable, provided, or expected</skos:definition>
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0067"/>
    <skos:prefLabel xml:lang="en">Right</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dct:contributor>Harshvardhan J. Pandit, Beatriz Esteves, Georg P. Krog</dct:contributor>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#DeliveryOfGoods">
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#Purpose"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2019-04-05</dct:created>
    <skos:related rdf:resource="https://specialprivacy.ercim.eu/vocabs/purposes#Delivery"/>
    <skos:prefLabel xml:lang="en">Delivery of Goods</skos:prefLabel>
    <dct:contributor>Harshvardhan J. Pandit, Javier Fernández, Axel Polleres, Elmar Kiesling, Fajar Ekaputra, Simon Steyskal</dct:contributor>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Purposes associated with delivering goods and services requested or asked by consumer</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RequestedServiceProvision"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#RequestRequiredActionPerformed">
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#RequestStatus"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-11-30</dct:created>
    <skos:prefLabel xml:lang="en">Request Required Action Performed</skos:prefLabel>
    <skos:definition xml:lang="en">State of a request's required action having been performed by the other party</skos:definition>
    <dct:contributor>Harshvardhan J. Pandit</dct:contributor>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RequestStatus"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#hasImpactAssessment">
    <rdfs:subPropertyOf rdf:resource="https://w3id.org/dpv/owl#hasAssessment"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <skos:definition xml:lang="en">Indicates an impact assessment associated with the specific context</skos:definition>
    <dcam:rangeIncludes rdf:resource="https://w3id.org/dpv/owl#ImpactAssessment"/>
    <skos:prefLabel xml:lang="en">has impact assessment</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <schema:rangeIncludes rdf:resource="https://w3id.org/dpv/owl#ImpactAssessment"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-14</dct:created>
    <dct:contributor>Harshvardhan J. Pandit</dct:contributor>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#Likelihood">
    <skos:scopeNote xml:lang="en">Likelihood can be expressed in a subjective manner, such as 'Unlikely', or in a quantitative manner such as "Twice in a Day" (frequency per period). The suggestion is to use quantitative values, or to associate them with subjective terms used so as to enable accurate interpretations and interoperability. See the concepts related to Frequency and Duration for possible uses as a combination to express Likelihood.</skos:scopeNote>
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0068"/>
    <skos:prefLabel xml:lang="en">Likelihood</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-07-22</dct:created>
    <skos:definition xml:lang="en">The likelihood or probability or chance of something taking place or occuring</skos:definition>
    <dct:contributor>Harshvardhan J. Pandit</dct:contributor>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#Data">
    <skos:prefLabel xml:lang="en">Data</skos:prefLabel>
    <dct:contributor>Harshvardhan J. Pandit</dct:contributor>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <skos:definition xml:lang="en">A broad concept representing  'data' or 'information'</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-01-19</dct:created>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#SecondaryImportance">
    <skos:definition xml:lang="en">Indication of 'secondary' or 'minor' or 'auxiliary' importance</skos:definition>
    <dct:contributor>Harshvardhan J. Pandit, Paul Ryan, Georg P. Krog, Julian Flake, Beatriz Esteves</dct:contributor>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#Importance"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-02-11</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <skos:prefLabel xml:lang="en">Secondary Importance</skos:prefLabel>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Importance"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#hasDataVolume">
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <skos:definition xml:lang="en">Indicates the volume of data</skos:definition>
    <dcam:rangeIncludes rdf:resource="https://w3id.org/dpv/owl#DataVolume"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-06-22</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:prefLabel xml:lang="en">has data volume</skos:prefLabel>
    <schema:rangeIncludes rdf:resource="https://w3id.org/dpv/owl#DataVolume"/>
    <rdfs:subPropertyOf rdf:resource="https://w3id.org/dpv/owl#hasScale"/>
    <dct:contributor>Harshvardhan J. Pandit</dct:contributor>
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#Client">
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-04-06</dct:created>
    <dct:contributor>Harshvardhan J. Pandit, Georg P. Krog, Julian Flake, Paul Ryan, Beatriz Esteves</dct:contributor>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#DataSubject"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:prefLabel xml:lang="en">Client</skos:prefLabel>
