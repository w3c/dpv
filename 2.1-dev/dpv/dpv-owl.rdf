  <rdf:Description rdf:about="https://w3id.org/dpv/owl#ConfidentialityAgreement">
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-02-09</dct:created>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#LegalMeasure"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">Agreements that enforce confidentiality for e.g. to protect business, professional, or company secrets</skos:definition>
    <dct:source xml:lang="en">DGA 3.1.a</dct:source>
    <skos:prefLabel xml:lang="en">Confidentiality Agreement</skos:prefLabel>
