  <rdf:Description rdf:about="https://w3id.org/dpv/owl#ConsentWithdrawn">
    <skos:scopeNote xml:lang="en">This state can be considered a form of 'revocation' of consent, where the revocation can only be performed by the data subject. Therefore we suggest using ConsentRevoked when it is a non-data-subject entity, and ConsentWithdrawn when it is the data subject</skos:scopeNote>
    <dct:source rdf:nodeID="N59f7877103be499a82c700798b4b5f91"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#ConsentStatus"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:prefLabel xml:lang="en">Consent Withdrawn</skos:prefLabel>
    <dct:contributor>Georg P. Krog, Harshvardhan J. Pandit, Paul Ryan, Julian Flake</dct:contributor>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">The state where the consent is withdrawn or revoked specifically by the data subject and which prevents it from being further used as a valid state</skos:definition>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-06-22</dct:created>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#ConsentStatusInvalidForProcessing"/>
  </rdf:Description>
