    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-10-19</dct:created>
    <dcam:rangeIncludes rdf:resource="https://w3id.org/dpv/owl#Permission"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#DataTransferLegalBasis">
