    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Purpose"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#OptingOutFromProcess">
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#EntityPermissiveInvolvement"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">Involvement where entity can opt-out from specified context</skos:definition>
    <skos:prefLabel xml:lang="en">Opting out of Process</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
