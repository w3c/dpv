  <rdf:Description rdf:about="https://w3id.org/dpv/owl#Notice">
    <skos:definition xml:lang="en">A notice is an artefact for providing information, choices, or controls</skos:definition>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:contributor>Paul Ryan, David Hickey, Georg P. Krog, Harshvardhan J. Pandit</dct:contributor>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-09-08</dct:created>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#OrganisationalMeasure"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <skos:prefLabel xml:lang="en">Notice</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Notice refers to the information whereas Notification refers to the provision of that notice. In several cases, they are used interchangeably - for example Privacy Notice as a measure or control refers to both the information as well as the act of making it available. For 'active' contexts where this distinction is important, e.g. data breach notifications, see Notification concept.</skos:scopeNote>
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0017"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#OrganisationalMeasure"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#JITNotice">
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#OrganisationalMeasure"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:source rdf:nodeID="N502e4dd56299402990826d59252b781f"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-08-17</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <skos:prefLabel xml:lang="en">Just-in-time Notice</skos:prefLabel>
    <skos:definition xml:lang="en">A notice that is provided "just in time" when collecting information or performing an activity</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Notice"/>
  </rdf:Description>
