  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#DataBreachNotice">
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#OrganisationalMeasure"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-14</dct:created>
    <skos:definition xml:lang="en">A notice providing information about data breach(es) i.e. unauthorised transfer, access, use, or modification of data</skos:definition>
    <dct:contributor>Georg P. Krog, Paul Ryan, David Hickey, Beatriz Esteves, Harshvardhan J. Pandit</dct:contributor>
    <dct:source xml:lang="en"> DGA 21.5 GDPR 33</dct:source>
    <dct:source xml:lang="en">DGA 12.k</dct:source>
    <dct:source xml:lang="en"> GDPR 34</dct:source>
    <skos:prefLabel xml:lang="en">Data Breach Notice</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#SecurityIncidentNotice"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#NoticeLayer">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A layer within a layered notice where the layer can be used for providing specific information or controls</skos:definition>
    <skos:prefLabel xml:lang="en">Notice Layer</skos:prefLabel>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-08-17</dct:created>
    <dct:source rdf:nodeID="N7c83dec0b4c448358473599bc70f73ea"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
  </rdf:Description>
