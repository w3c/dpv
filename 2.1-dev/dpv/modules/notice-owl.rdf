  <rdf:Description rdf:about="https://w3id.org/dpv/owl#DataTransferNotice">
    <dct:source xml:lang="en">DGA 5.9</dct:source>
    <skos:definition xml:lang="en">Notice for the legal entity for the transfer of its data</skos:definition>
    <skos:prefLabel xml:lang="en">Data Transfer Notice</skos:prefLabel>
