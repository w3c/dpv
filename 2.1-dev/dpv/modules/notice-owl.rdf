    <dct:source rdf:nodeID="N35834f6286c842918e65f7b09157ad9b"/>
    <skos:definition xml:lang="en">A notice provided using the functionality provided by a device e.g. using the popup or alert feature</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Notice"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#PrivacyNotice">
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0022"/>
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0017"/>
    <skos:definition xml:lang="en">Represents a notice or document outlining information regarding privacy</skos:definition>
    <dct:contributor>Georg P. Krog, Paul Ryan, David Hickey, Harshvardhan J. Pandit</dct:contributor>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#OrganisationalMeasure"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-09-08</dct:created>
    <skos:prefLabel xml:lang="en">Privacy Notice</skos:prefLabel>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Notice"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#hasNoticeLayer">
    <skos:definition xml:lang="en">Indicates the use of a notice layer within a notice or to associate a layer with another layer</skos:definition>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-08-17</dct:created>
    <skos:prefLabel xml:lang="en">has notice layer</skos:prefLabel>
    <schema:domainIncludes rdf:resource="https://w3id.org/dpv/owl#Notice"/>
    <schema:domainIncludes rdf:resource="https://w3id.org/dpv/owl#NoticeLayer"/>
    <schema:rangeIncludes rdf:resource="https://w3id.org/dpv/owl#NoticeLayer"/>
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcam:domainIncludes rdf:resource="https://w3id.org/dpv/owl#Notice"/>
    <dcam:domainIncludes rdf:resource="https://w3id.org/dpv/owl#NoticeLayer"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dcam:rangeIncludes rdf:resource="https://w3id.org/dpv/owl#NoticeLayer"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#PrintedNotice">
    <dct:source rdf:nodeID="N6e9cfc2f222541b2be477cebb5b4898a"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
