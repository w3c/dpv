    <skos:prefLabel xml:lang="en">Data Transfer Record</skos:prefLabel>
    <skos:definition xml:lang="en">Record of data transfer activities</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#DataProcessingRecord"/>
  </rdf:Description>
