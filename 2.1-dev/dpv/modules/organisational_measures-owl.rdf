  <rdf:Description rdf:about="https://w3id.org/dpv/owl#DataSecurityManagement">
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#OrganisationalMeasure"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:prefLabel xml:lang="en">Data Security Management</skos:prefLabel>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-14</dct:created>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <skos:scopeNote xml:lang="en">Examples of data security management are assessing the appropriate security controls such as encryption, testing the implemented security controls, and ensuring it is protected and safeguarded from unintended actions</skos:scopeNote>
    <dct:contributor>Harshvardhan J. Pandit</dct:contributor>
    <skos:definition xml:lang="en">Measures associated with management of data security</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#DataGovernance"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#SecurityProcedure"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#SupportInformedConsentDecision">
