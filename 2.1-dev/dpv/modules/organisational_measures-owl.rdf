    <dct:contributor>Harshvardhan J. Pandit, Georg P. Krog</dct:contributor>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#ConsultationWithDataSubject"/>
  </rdf:Description>
