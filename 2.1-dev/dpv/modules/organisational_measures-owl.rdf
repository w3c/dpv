  <rdf:Description rdf:about="https://w3id.org/dpv/owl#RegulatorySandbox">
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-05-17</dct:created>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
