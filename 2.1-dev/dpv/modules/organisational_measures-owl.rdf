  <rdf:Description rdf:about="https://w3id.org/dpv/owl#SupportExchangeOfViews">
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:contributor>Beatriz Esteves, Harshvardhan J. Pandit</dct:contributor>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#OrganisationalMeasure"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:prefLabel xml:lang="en">Support Exchange of Views</skos:prefLabel>
    <dct:source xml:lang="en">DGA 2.15</dct:source>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-14</dct:created>
    <skos:definition xml:lang="en">Supporting individuals and entities in exchanging views e.g. regarding data processing purposes for their best interests</skos:definition>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#SupportEntityDecisionMaking"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#LegitimateInterestAssessment">
    <skos:prefLabel xml:lang="en">Legitimate Interest Assessment</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-09-08</dct:created>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#OrganisationalMeasure"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:contributor>Georg P. Krog, Harshvardhan J. Pandit, Paul Ryan</dct:contributor>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <skos:definition xml:lang="en">Indicates an assessment regarding the use of legitimate interest as a lawful basis by the data controller</skos:definition>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Assessment"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#DataInteroperabilityAssessment">
