  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#hasRiskLevel">
    <skos:prefLabel xml:lang="en">has risk level</skos:prefLabel>
    <schema:domainIncludes rdf:resource="https://w3id.org/dpv/owl#Risk"/>
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0071"/>
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0068"/>
    <dcam:domainIncludes rdf:resource="https://w3id.org/dpv/owl#Risk"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcam:rangeIncludes rdf:resource="https://w3id.org/dpv/owl#RiskLevel"/>
    <dct:contributor>Harshvardhan J. Pandit, Georg P. Krog, Paul Ryan, Julian Flake</dct:contributor>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-07-20</dct:created>
    <skos:definition xml:lang="en">Indicates the associated risk level associated with a risk</skos:definition>
    <schema:rangeIncludes rdf:resource="https://w3id.org/dpv/owl#RiskLevel"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#hasConsequenceOn">
    <dct:contributor>Harshvardhan J. Pandit, Georg P. Krog</dct:contributor>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-11-24</dct:created>
    <schema:domainIncludes rdf:resource="https://w3id.org/dpv/owl#Consequence"/>
    <dcam:domainIncludes rdf:resource="https://w3id.org/dpv/owl#Consequence"/>
    <skos:prefLabel xml:lang="en">has consequence on</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <skos:definition xml:lang="en">Indicates the thing (e.g. plan, process, or entity) affected by a consequence</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#hasImpactOn">
    <rdfs:subPropertyOf rdf:resource="https://w3id.org/dpv/owl#hasConsequenceOn"/>
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0068"/>
    <skos:definition xml:lang="en">Indicates the thing (e.g. plan, process, or entity) affected by an impact</skos:definition>
    <dcam:domainIncludes rdf:resource="https://w3id.org/dpv/owl#Impact"/>
    <schema:domainIncludes rdf:resource="https://w3id.org/dpv/owl#Impact"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-05-18</dct:created>
