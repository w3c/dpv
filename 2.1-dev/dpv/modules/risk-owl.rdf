>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#ConsequenceAsSideEffect">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:contributor>Harshvardhan J. Pandit</dct:contributor>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#Consequence"/>
    <skos:definition xml:lang="en">The consequence(s) possible or arising as a side-effect of specified context</skos:definition>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-03-30</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:prefLabel xml:lang="en">Consequence as Side-Effect</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#PIA">
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#OrganisationalMeasure"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dct:contributor>Georg P. Krog, Harshvardhan J. Pandit, Paul Ryan</dct:contributor>
    <skos:prefLabel xml:lang="en">Privacy Impact Assessment (PIA)</skos:prefLabel>
    <skos:definition xml:lang="en">Impact assessment regarding privacy risks</skos:definition>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2020-11-04</dct:created>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#ImpactAssessment"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#FRIA">
    <dct:source xml:lang="en">AI Act Art.27</dct:source>
    <skos:definition xml:lang="en">Impact assessment which assesses the potential and actual impact on fundamental rights occuring due to processing activities</skos:definition>
    <skos:prefLabel xml:lang="en">Fundamental Rights Impact Assessment (FRIA)</skos:prefLabel>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#OrganisationalMeasure"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:scopeNote xml:lang="en">The fundamental rights and freedoms may be those defined in law or other norms, and may be bound to a jurisdiction - for example see EU Charter of Fundamental Rights</skos:scopeNote>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-14</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:contributor>Harshvardhan J. Pandit</dct:contributor>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RightsImpactAssessment"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#hasRiskAssessment">
    <dcam:rangeIncludes rdf:resource="https://w3id.org/dpv/owl#RiskAssessment"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-14</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <skos:prefLabel xml:lang="en">has risk assessment</skos:prefLabel>
    <rdfs:subPropertyOf rdf:resource="https://w3id.org/dpv/owl#hasAssessment"/>
    <schema:rangeIncludes rdf:resource="https://w3id.org/dpv/owl#RiskAssessment"/>
    <dct:contributor>Harshvardhan J. Pandit</dct:contributor>
    <skos:definition xml:lang="en">Indicates an associated risk assessment</skos:definition>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#Risk">
    <dct:contributor>Harshvardhan J. Pandit</dct:contributor>
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0068"/>
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0071"/>
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0027"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RiskConcept"/>
    <skos:scopeNote xml:lang="en">Risks can be associated with one or more different concepts such as purpose, processing, personal data, technical or organisational measure</skos:scopeNote>
    <skos:prefLabel xml:lang="en">Risk</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">A risk or possibility or uncertainty of negative effects, impacts, or consequences</skos:definition>
    <dct:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-08-16</dct:modified>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2020-11-18</dct:created>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#Consequence">
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0068"/>
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0071"/>
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0027"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RiskConcept"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-01-26</dct:created>
    <skos:definition xml:lang="en">The consequence(s) possible or arising from specified context</skos:definition>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-08-16</dct:modified>
    <skos:prefLabel xml:lang="en">Consequence</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dct:contributor>Harshvardhan J. Pandit</dct:contributor>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#">
    <owl:versionIRI rdf:resource="https://w3id.org/dpv/2.1-dev/owl#"/>
    <profile:hasResource rdf:resource="https://w3id.org/dpv/owl#serialisation-n3"/>
    <profile:hasResource rdf:resource="https://w3id.org/dpv/owl#serialisation-ttl"/>
    <profile:hasResource rdf:resource="https://w3id.org/dpv/examples"/>
    <profile:hasResource rdf:resource="https://w3id.org/dpv/primer"/>
