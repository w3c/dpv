    <schema:version>2.1-dev</schema:version>
    <dct:description xml:lang="en">The Data Privacy Vocabulary (DPV) provides terms (classes and properties) to represent information about processing of personal data, for example - purposes, processing operations, personal data, technical and organisational measures.</dct:description>
    <dct:source rdf:resource="https://www.w3.org/groups/cg/dpvcg/"/>
    <foaf:logo rdf:resource="https://w3id.org/dpv/media/logo.png"/>
    <profile:isProfileOf rdf:resource="http://www.w3.org/2002/07/owl"/>
    <profile:isProfileOf rdf:resource="https://w3id.org/dpv/owl#"/>
    <rdfs:Label xml:lang="en">DPV</rdfs:Label>
    <owl:versionInfo>2.1-dev</owl:versionInfo>
    <dct:issued xml:lang="en">2022-08-18</dct:issued>
    <dct:conformsTo>http://www.w3.org/2000/01/rdf-schema</dct:conformsTo>
    <dct:conformsTo>http://www.w3.org/2004/02/skos/core</dct:conformsTo>
    <dct:conformsTo rdf:resource="http://www.w3.org/2002/07/owl"/>
    <dct:publisher rdf:resource="https://www.w3.org/"/>
    <vann:preferredNamespaceUri>https://w3id.org/dpv#</vann:preferredNamespaceUri>
    <bibo:doi>10.5281/zenodo.12505841</bibo:doi>
    <vann:preferredNamespacePrefix>dpv</vann:preferredNamespacePrefix>
    <dct:title xml:lang="en">Data Privacy Vocabulary (DPV)</dct:title>
    <dct:identifier>https://w3id.org/dpv</dct:identifier>
    <dct:bibliographicCitation>Data Privacy Vocabulary (DPV) -- Version 2. Harshvardhan J. Pandit, Beatriz Esteves, Georg P. Krog, Paul Ryan, Delaram Golpayegani, Julian Flake https://doi.org/10.48550/arXiv.2404.13426</dct:bibliographicCitation>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#RiskConcept">
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <skos:definition xml:lang="en">Parent concept for combining concepts associated with risk assessment such as actual and potential Risk, Risk Source, Consequences, and Impacts</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:prefLabel xml:lang="en">Risk Concept</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:scopeNote xml:lang="en">RiskConcept is a generic concept used for creation of specific taxonomies in the RISK extension to provide guidance on how a concept can potentially be a risk, risk source, consequence, and impact. It is not intended to be used directly and is only created for organisation of concepts in DPV vocabularies</skos:scopeNote>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-08-16</dct:created>
    <dct:contributor>Delaram Golpayegani, Rob Brennan, Harshvardhan J. Pandit</dct:contributor>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#RightsImpactAssessment">
    <skos:scopeNote xml:lang="en">The rights and freedoms may be those defined in law or other norms, and may be bound to a jurisdiction</skos:scopeNote>
    <dct:contributor>Harshvardhan J. Pandit</dct:contributor>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#OrganisationalMeasure"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">Impact assessment which involves determining the impact on rights and freedoms</skos:definition>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-14</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:prefLabel xml:lang="en">Rights Impact Assessment</skos:prefLabel>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#ImpactAssessment"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#hasSeverity">
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dcam:rangeIncludes rdf:resource="https://w3id.org/dpv/owl#Severity"/>
    <dct:contributor>Harshvardhan J. Pandit, Georg P. Krog, Paul Ryan, Julian Flake</dct:contributor>
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0068"/>
    <schema:rangeIncludes rdf:resource="https://w3id.org/dpv/owl#Severity"/>
    <skos:prefLabel xml:lang="en">has severity</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-07-20</dct:created>
    <skos:definition xml:lang="en">Indicates the severity associated with a concept</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#SecurityAssessment">
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#OrganisationalMeasure"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-08-17</dct:created>
    <skos:prefLabel xml:lang="en">Security Assessment</skos:prefLabel>
    <dct:source rdf:nodeID="Neb4548effc8345fabda192c26b762436"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Assessment of security intended to identity gaps, vulnerabilities, risks, and effectiveness of controls</skos:definition>
    <dct:contributor>Harshvardhan J. Pandit</dct:contributor>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RiskAssessment"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#hasResidualRisk">
    <skos:prefLabel xml:lang="en">has residual risk</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dcam:rangeIncludes rdf:resource="https://w3id.org/dpv/owl#ResidualRisk"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-07-20</dct:created>
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <schema:rangeIncludes rdf:resource="https://w3id.org/dpv/owl#ResidualRisk"/>
    <dct:contributor>Harshvardhan J. Pandit, Georg P. Krog, Paul Ryan, Julian Flake</dct:contributor>
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0068"/>
    <schema:domainIncludes rdf:resource="https://w3id.org/dpv/owl#Risk"/>
    <dcam:domainIncludes rdf:resource="https://w3id.org/dpv/owl#Risk"/>
    <skos:definition xml:lang="en">Indicates the associated risk is the remaining or residual risk from applying mitigation measures or treatments to this risk</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#hasRisk">
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2020-11-18</dct:created>
    <dct:contributor>Harshvardhan J. Pandit</dct:contributor>
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0068"/>
    <schema:rangeIncludes rdf:resource="https://w3id.org/dpv/owl#Risk"/>
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <skos:prefLabel xml:lang="en">has risk</skos:prefLabel>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dcam:rangeIncludes rdf:resource="https://w3id.org/dpv/owl#Risk"/>
    <skos:definition xml:lang="en">Indicates applicability of Risk for this concept</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#DPIA">
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#OrganisationalMeasure"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2020-11-04</dct:created>
    <dct:source xml:lang="en">GDPR Art. 35</dct:source>
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0056"/>
    <dct:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-14</dct:modified>
    <skos:scopeNote xml:lang="en">Specific requirements and procedures for DPIA are defined in GDPR Art.35</skos:scopeNote>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:prefLabel xml:lang="en">Data Protection Impact Assessment (DPIA)</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <skos:definition xml:lang="en">Impact assessment determining the potential and actual impact of processing activities on individuals or groups of individuals and taking into account the impacts of activities on their rights and freedoms</skos:definition>
    <dct:contributor>Georg P. Krog, Harshvardhan J. Pandit, Paul Ryan</dct:contributor>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RightsImpactAssessment"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#isMitigatedByMeasure">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <dcam:domainIncludes rdf:resource="https://w3id.org/dpv/owl#Risk"/>
    <dct:contributor>Harshvardhan J. Pandit</dct:contributor>
    <dcam:rangeIncludes rdf:resource="https://w3id.org/dpv/owl#RiskMitigationMeasure"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2022-02-09</dct:created>
    <vann:example rdf:resource="https://w3id.org/dpv/examples/owl#E0068"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <schema:domainIncludes rdf:resource="https://w3id.org/dpv/owl#Risk"/>
    <skos:prefLabel xml:lang="en">is mitigated by measure</skos:prefLabel>
    <rdfs:subPropertyOf rdf:resource="https://w3id.org/dpv/owl#hasTechnicalOrganisationalMeasure"/>
    <schema:rangeIncludes rdf:resource="https://w3id.org/dpv/owl#RiskMitigationMeasure"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:definition xml:lang="en">Indicate a risk is mitigated by specified measure</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#serialisation-rdf">
    <profile:hasRole rdf:resource="http://www.w3.org/ns/dx/prof/role/vocabulary"/>
    <rdf:type rdf:resource="http://www.w3.org/ns/dx/prof/ResourceDescriptor"/>
    <profile:hasArtifact rdf:resource="https://w3id.org/dpv/dpv/dpv-owl.rdf"/>
    <dct:format rdf:resource="https://www.iana.org/assignments/media-types/application/rdf+xml"/>
    <dct:title>Data Privacy Vocabulary (DPV) - RDF/XML serialiation</dct:title>
    <dct:conformsTo rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv/owl#DataBreachImpactAssessment">
    <skos:prefLabel xml:lang="en">Data Breach Impact Assessment (DBIA)</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv/owl#OrganisationalMeasure"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
    <skos:definition xml:lang="en">Impact Assessment concerning the consequences and impacts of a data breach</skos:definition>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-04-15</dct:created>
    <skos:scopeNote xml:lang="en">Data Breach assessments can require additional non-security related assessments such as GDPR Art.34 Rights Impact Assessment</skos:scopeNote>
    <dct:contributor>Harshvardhan J. Pandit</dct:contributor>
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#RightsImpactAssessment"/>
  </rdf:Description>
