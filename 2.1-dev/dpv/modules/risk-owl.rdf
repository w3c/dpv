  <rdf:Description rdf:about="https://w3id.org/dpv/owl#RiskMitigationMeasure">
    <rdfs:subClassOf rdf:resource="https://w3id.org/dpv/owl#TechnicalOrganisationalMeasure"/>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <skos:prefLabel xml:lang="en">Risk Mitigation Measure</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">Measures intended to mitigate, minimise, or prevent risk.</skos:definition>
    <dct:contributor>Georg P. Krog, Harshvardhan J. Pandit, Paul Ryan</dct:contributor>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv/owl#"/>
