    <dcam:rangeIncludes rdf:resource="https://w3id.org/dpv/owl#Risk"/>
    <skos:definition xml:lang="en">Indicates risks mitigated by this concept</skos:definition>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <schema:domainIncludes rdf:resource="https://w3id.org/dpv/owl#RiskMitigationMeasure"/>
