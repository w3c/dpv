  <rdf:Description rdf:about="https://w3id.org/dpv#Anonymise">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv#Processing"/>
    <skos:prefLabel xml:lang="en">Anonymise</skos:prefLabel>
    <skos:definition xml:lang="en">to irreversibly alter personal data in such a way that an unique data subject can no longer be identified directly or indirectly or in combination with other data</skos:definition>
    <skos:broader rdf:resource="https://w3id.org/dpv#Transform"/>
    <skos:related rdf:resource="https://specialprivacy.ercim.eu/vocabs/processing#Anonymise"/>
    <dct:source rdf:nodeID="N9ad56c5f7ccd4130ac5bc3bab4a54b31"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2019-05-07</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv#"/>
    <skos:inScheme rdf:resource="https://w3id.org/dpv#processing-classes"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv#Restrict">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv#Processing"/>
    <skos:prefLabel xml:lang="en">Restrict</skos:prefLabel>
    <skos:definition xml:lang="en">to apply a restriction on the processing of specific records</skos:definition>
    <skos:broader rdf:resource="https://w3id.org/dpv#Transform"/>
    <dct:source rdf:nodeID="Nd6af904b753b4470b78d73f59c240222"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2019-05-07</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv#"/>
    <skos:inScheme rdf:resource="https://w3id.org/dpv#processing-classes"/>
  </rdf:Description>
