  <rdf:Description rdf:about="https://w3id.org/dpv#Remove">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv#Processing"/>
    <skos:prefLabel xml:lang="en">Remove</skos:prefLabel>
    <skos:definition xml:lang="en">to destruct or erase data</skos:definition>
    <skos:broader rdf:resource="https://w3id.org/dpv#Processing"/>
    <dct:source rdf:nodeID="Nb944c02d489a4a0ea24ea2f1f5ee0019"/>
