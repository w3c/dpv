  <rdf:Description rdf:about="https://w3id.org/dpv#Copy">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv#Processing"/>
    <skos:prefLabel xml:lang="en">Copy</skos:prefLabel>
    <skos:definition xml:lang="en">to produce an exact reproduction of the data</skos:definition>
    <skos:broader rdf:resource="https://w3id.org/dpv#Processing"/>
    <skos:related rdf:resource="https://specialprivacy.ercim.eu/vocabs/processing#Copy"/>
    <dct:source rdf:nodeID="N01b4338de16d46ca8aa9a47cc2de2c53"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2019-05-07</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv#"/>
    <skos:inScheme rdf:resource="https://w3id.org/dpv#processing-classes"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv#Derive">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv#Processing"/>
    <skos:prefLabel xml:lang="en">Derive</skos:prefLabel>
    <skos:definition xml:lang="en">to create new derivative data from the original data</skos:definition>
    <skos:broader rdf:resource="https://w3id.org/dpv#Obtain"/>
    <skos:related rdf:resource="https://specialprivacy.ercim.eu/vocabs/processing#Derive"/>
    <skos:scopeNote xml:lang="en">Derive indicates data is present or obtainable from existing data. For data that is created without such existence, see Infer.</skos:scopeNote>
    <dct:source rdf:nodeID="Nde5b249c73154ba8a903f9786ad919d2"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2019-05-07</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <vann:example rdf:resource="https://w3id.org/dpv/examples#E0009"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv#"/>
    <skos:inScheme rdf:resource="https://w3id.org/dpv#processing-classes"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv#Transmit">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv#Processing"/>
    <skos:prefLabel xml:lang="en">Transmit</skos:prefLabel>
    <skos:definition xml:lang="en">to send out data</skos:definition>
    <skos:broader rdf:resource="https://w3id.org/dpv#Disclose"/>
    <dct:source rdf:nodeID="N2cc3f0e4839648a29e73d14a52210a1a"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2019-05-07</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv#"/>
    <skos:inScheme rdf:resource="https://w3id.org/dpv#processing-classes"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv#hasProcessing">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">has processing</skos:prefLabel>
    <skos:definition xml:lang="en">Indicates association with Processing</skos:definition>
    <dcam:rangeIncludes rdf:resource="https://w3id.org/dpv#Processing"/>
    <schema:rangeIncludes rdf:resource="https://w3id.org/dpv#Processing"/>
    <dct:source rdf:nodeID="N885b3c6a91e1436d9ef88555a8bca72f"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2019-04-04</dct:created>
