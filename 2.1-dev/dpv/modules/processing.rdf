  <rdf:Description rdf:about="https://w3id.org/dpv#Alter">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv#Processing"/>
    <skos:prefLabel xml:lang="en">Alter</skos:prefLabel>
    <skos:definition xml:lang="en">to change the data without changing it into something else</skos:definition>
    <skos:broader rdf:resource="https://w3id.org/dpv#Transform"/>
    <dct:source rdf:nodeID="Na6b330d4f6094b93bc7e8f5c2634a62b"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2019-05-07</dct:created>
    <sw:term_status xml:lang="en">accepted</sw:term_status>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/dpv#"/>
    <skos:inScheme rdf:resource="https://w3id.org/dpv#processing-classes"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/dpv#Obtain">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Class"/>
    <rdf:type rdf:resource="https://w3id.org/dpv#Processing"/>
    <skos:prefLabel xml:lang="en">Obtain</skos:prefLabel>
    <skos:definition xml:lang="en">to solicit or gather data from someone</skos:definition>
    <skos:broader rdf:resource="https://w3id.org/dpv#Processing"/>
    <dct:source rdf:nodeID="N2571edc7ec9f4bbda7ed1630c299fa26"/>
    <dct:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2019-05-07</dct:created>
